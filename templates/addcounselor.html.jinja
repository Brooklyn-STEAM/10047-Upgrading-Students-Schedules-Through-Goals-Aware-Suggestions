<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
    <title>CourseTrack - Add your Counselor</title>
    <link href= "/static/styles.css" rel="stylesheet" >
  </head>
    <body class="bg-gradient-to-b from-emerald-50 to-emerald-100 min-h-screen flex flex-col">
    {% include "components/navbar.html.jinja" %}
    <main class="container mx-auto my-10 px-4 py-8 flex-grow">

    <h1 class="text-center font-semibold text-4xl mb-5">Add your Counselor Here</h1>

    <form method="post" class="space-y-6 bg-white p-6 rounded-lg shadow-md" action="/student/recommendation/addcounselor/processing">

      <!-- Counselor Information -->
      <div>
        <h3 class="text-lg font-semibold text-gray-700 mb-4">Counselor Information</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">
              First Name
            </label>
            <input name="firstname" type="text" placeholder="John" required
              class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none">
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">
              Last Name
            </label>
            <input name="lastname" type="text" placeholder="Doe" required
              class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none">
          </div>

          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-600 mb-1">
              Email Address
            </label>
            <input name="emailaddress" type="email" placeholder="counselor@example.com" required
              class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none">
          </div>

          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-600 mb-1">
              Student ID
            </label>
            <input name="studentid" type="tel" placeholder="ex. 1234567890" required
              class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none">
          </div>

          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-600 mb-1">
              Grade
            </label>
            <input name="grade" type="number" min="9" max="12" placeholder="From grades 9-12" required
              class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none">
          </div>

        </div>
      </div>
        <div class="mt-4">
          <label class="block text-sm font-medium text-gray-600 mb-1">
            Additional Notes (Optional)
          </label>
          <textarea name="comments" rows="4" placeholder="Add any message or context for your counselor..."
            class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none"></textarea>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex justify-end gap-4 pt-4">
        <button type="reset"
          class="px-6 py-2 rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-100 transition">
          Clear
        </button>

        <button class="px-6 py-2 rounded-lg bg-emerald-600 text-white hover:bg-emerald-700 transition shadow-md" type="submit">
        {% if data %}
        Update Counselor
        {% else %}
        Add Counselor
        {% endif %}
        </button>
      </div>

    </form>
    </main>

    {% include "components/footer.html.jinja" %}
    </body>
</html>