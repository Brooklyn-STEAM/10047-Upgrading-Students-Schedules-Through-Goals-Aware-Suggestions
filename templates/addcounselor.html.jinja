<!doctype html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
    <title>CourseTrack - Add Counselor</title>
    <link href="/static/styles.css" rel="stylesheet">
  </head>

  <body class="bg-gradient-to-br from-emerald-50 via-white to-emerald-100 min-h-screen flex flex-col text-gray-800">
{% include "components/navbar.html.jinja" %}

<main class="flex-grow flex items-center justify-center px-4 py-12">
  
  <div class="w-full max-w-2xl">
    
    <!-- Header -->
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900">
        Add Your Counselor
      </h1>
      <p class="mt-2 text-gray-500">
        Connect with your school counselor for recommendations and guidance
      </p>
    </div>

    <!-- Form Card -->
    <form method="post"
          action="/student/recommendation/addcounselor/processing"
          class="bg-white/80 backdrop-blur-lg border border-gray-200 rounded-2xl shadow-xl p-8 space-y-8">

      <!-- Counselor Section -->
      <div>
        <h2 class="text-lg font-semibold text-gray-700 mb-4 border-b pb-2">
          Counselor Information
        </h2>

        <div class="space-y-5">
          
          <!-- Dropdown -->
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">
              Select Your Counselor
            </label>

            <select name="counselor_id"
                    required
                    class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 shadow-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition">

              <option value="">Choose a counselor</option>

              {% for c in counselors %}
              <option value="{{ c.ID }}">
                {{ c.Name }} ({{ c.Email }})
              </option>
              {% endfor %}

            </select>
          </div>

          <!-- Grade Radio Cards -->
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-3">
              Grade Level
            </label>

            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">

              <!-- Grade 9 -->
              <label class="cursor-pointer">
                <input type="radio" name="grade" value="9" required class="peer hidden">
                <div class="text-center px-4 py-3 rounded-xl border border-gray-300 
                            peer-checked:border-emerald-500 
                            peer-checked:bg-emerald-50 
                            peer-checked:text-emerald-700
                            hover:border-emerald-400 
                            transition font-medium shadow-sm">
                  9th Grade
                </div>
              </label>

              <!-- Grade 10 -->
              <label class="cursor-pointer">
                <input type="radio" name="grade" value="10" class="peer hidden">
                <div class="text-center px-4 py-3 rounded-xl border border-gray-300 
                            peer-checked:border-emerald-500 
                            peer-checked:bg-emerald-50 
                            peer-checked:text-emerald-700
                            hover:border-emerald-400 
                            transition font-medium shadow-sm">
                  10th Grade
                </div>
              </label>

              <!-- Grade 11 -->
              <label class="cursor-pointer">
                <input type="radio" name="grade" value="11" class="peer hidden">
                <div class="text-center px-4 py-3 rounded-xl border border-gray-300 
                            peer-checked:border-emerald-500 
                            peer-checked:bg-emerald-50 
                            peer-checked:text-emerald-700
                            hover:border-emerald-400 
                            transition font-medium shadow-sm">
                  11th Grade
                </div>
              </label>

              <!-- Grade 12 -->
              <label class="cursor-pointer">
                <input type="radio" name="grade" value="12" class="peer hidden">
                <div class="text-center px-4 py-3 rounded-xl border border-gray-300 
                            peer-checked:border-emerald-500 
                            peer-checked:bg-emerald-50 
                            peer-checked:text-emerald-700
                            hover:border-emerald-400 
                            transition font-medium shadow-sm">
                  12th Grade
                </div>
              </label>

            </div>
          </div>

        </div>
      </div>

      <!-- Notes Section -->
      <div>
        <h2 class="text-lg font-semibold text-gray-700 mb-2">
          Additional Notes
        </h2>

        <textarea name="comments"
                  rows="4"
                  placeholder="Add any message or context for your counselor..."
                  class="w-full rounded-lg border border-gray-300 px-4 py-2.5 shadow-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition resize-none"></textarea>
      </div>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4 pt-4 border-t">

        <button type="reset"
                class="w-full sm:w-auto px-5 py-2.5 rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-100 hover:text-gray-800 transition">
          Clear Form
        </button>

        <button type="submit"
                class="w-full sm:w-auto px-6 py-2.5 rounded-lg bg-emerald-600 text-white font-medium hover:bg-emerald-700 active:scale-[0.98] transition shadow-md">
          Add Counselor
        </button>

      </div>

    </form>

  </div>

</main>

{% include "components/footer.html.jinja" %}


  </body>
</html>


  </body>
</html>

