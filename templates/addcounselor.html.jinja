<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

  <link rel="icon" type="image/png"
        href="{{ url_for('static', filename='images/logo.png') }}">

  <title>CourseTrack - Add Counselor</title>

  <link href="/static/styles.css" rel="stylesheet">
</head>

<body class="bg-gradient-to-br from-emerald-50 via-white to-emerald-100 min-h-screen flex flex-col text-gray-800">

{% include "components/navbar.html.jinja" %}

<main class="flex-grow flex items-center justify-center px-4 py-12">

  <div class="w-full max-w-2xl">

    <!-- Header -->
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900">
        Add Your Counselor
      </h1>

      <p class="mt-2 text-gray-500">
        Connect with your school counselor for recommendations and guidance
      </p>
    </div>

    <!-- Flash Messages -->
    {% with messages = get_flashed_messages(with_categories=true) %}
      {% if messages %}
        <div class="mb-6 space-y-3">

          {% for category, message in messages %}

            <div class="px-4 py-3 rounded-lg shadow-sm border
              {% if category == 'danger' %}
                bg-red-50 text-red-700 border-red-200
              {% elif category == 'warning' %}
                bg-yellow-50 text-yellow-700 border-yellow-200
              {% elif category == 'success' %}
                bg-emerald-50 text-emerald-700 border-emerald-200
              {% else %}
                bg-gray-50 text-gray-700 border-gray-200
              {% endif %}
            ">
              {{ message }}
            </div>

          {% endfor %}

        </div>
      {% endif %}
    {% endwith %}

    <!-- FORM -->
    <form method="POST"
          action="/student/recommendation/addcounselor/processing"
          class="bg-white/80 backdrop-blur-lg border border-gray-200 rounded-2xl shadow-xl p-8 space-y-8">

      <!-- Counselor Section -->
      <div>

        <h2 class="text-lg font-semibold text-gray-700 mb-4 border-b pb-2">
          Counselor Information
        </h2>

        <div class="space-y-5">

          <!-- SEARCH -->
          <div id="searchContainer" class="relative">

            <label class="block text-sm font-medium text-gray-600 mb-1">
              Search Counselor
            </label>

            <!-- SEARCH INPUT -->
            <input
              type="text"
              id="counselorSearch"
              placeholder="Search by counselor name or email..."
              autocomplete="off"
              class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 shadow-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition"
            >

            <!-- HIDDEN SELECTED VALUE -->
            <input
              type="hidden"
              name="counselor_id"
              id="selectedCounselor"
              required
            >

            <!-- DROPDOWN -->
            <div
              id="counselorResults"
              class="absolute z-50 mt-2 w-full bg-white border border-gray-200 rounded-xl shadow-lg max-h-72 overflow-y-auto hidden"
            >

              {% for c in counselors %}

                <button
                  type="button"
                  onclick="selectCounselor('{{ c.ID }}', '{{ c.Name }}', '{{ c.Email }}')"
                  class="counselor-option w-full text-left px-4 py-3 hover:bg-emerald-50 transition border-b border-gray-100"
                >

                  <div class="font-medium text-gray-800">
                    {{ c.Name }}
                  </div>

                  <div class="text-sm text-gray-500">
                    {{ c.Email }}
                  </div>

                </button>

              {% endfor %}

            </div>

          </div>

          <!-- SELECTED COUNSELOR CARD -->
          <div
            id="selectedCounselorCard"
            class="hidden bg-emerald-50 border border-emerald-200 rounded-xl p-4"
          >

            <div class="flex items-center justify-between gap-4">

              <div>

                <p class="text-sm text-emerald-700 font-medium">
                  Counselor Selected
                </p>

                <h3
                  id="selectedCounselorName"
                  class="text-lg font-bold text-emerald-900"
                >
                </h3>

                <p
                  id="selectedCounselorEmail"
                  class="text-sm text-emerald-700"
                >
                </p>

              </div>

              <!-- PROFILE BUTTON -->
              <a
                id="counselorProfileLink"
                href="#"
                class="inline-flex items-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700 transition"
              >
                View Profile
              </a>

            </div>

          </div>

          <!-- Grade -->
          <div>

            <label class="block text-sm font-medium text-gray-600 mb-3">
              Grade Level
            </label>

            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">

              {% for grade in ['9', '10', '11', '12'] %}

              <label class="cursor-pointer">
                <input type="radio"
                       name="grade"
                       value="{{ grade }}"
                       required
                       class="peer hidden">

                <div class="text-center px-4 py-3 rounded-xl border border-gray-300
                            peer-checked:border-emerald-500
                            peer-checked:bg-emerald-50
                            peer-checked:text-emerald-700
                            hover:border-emerald-400
                            transition font-medium shadow-sm">

                  {{ grade }}th Grade

                </div>
              </label>

              {% endfor %}

            </div>

          </div>

        </div>

      </div>

      <!-- Notes -->
      <div>

        <h2 class="text-lg font-semibold text-gray-700 mb-2">
          Additional Notes
        </h2>

        <textarea
          name="comments"
          rows="4"
          placeholder="Add any message or context for your counselor..."
          class="w-full rounded-lg border border-gray-300 px-4 py-2.5 shadow-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition resize-none"
        ></textarea>

      </div>

      <!-- ACTIONS -->
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4 pt-4 border-t">

        <button
          type="reset"
          class="w-full sm:w-auto px-5 py-2.5 rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-100 hover:text-gray-800 transition"
        >
          Clear Form
        </button>

        <button
          type="submit"
          class="w-full sm:w-auto px-6 py-2.5 rounded-lg bg-emerald-600 text-white font-medium hover:bg-emerald-700 active:scale-[0.98] transition shadow-md"
        >
          Add Counselor
        </button>

      </div>

    </form>

  </div>

</main>

{% include "components/footer.html.jinja" %}

<!-- JAVASCRIPT -->
<script>

  const searchInput = document.getElementById("counselorSearch");
  const dropdown = document.getElementById("counselorResults");

  const selectedCounselor = document.getElementById("selectedCounselor");

  const selectedCard = document.getElementById("selectedCounselorCard");

  const counselorName = document.getElementById("selectedCounselorName");
  const counselorEmail = document.getElementById("selectedCounselorEmail");

  const profileLink = document.getElementById("counselorProfileLink");

  // -----------------------------------
  // SHOW ALL RESULTS WHEN CLICKING
  // -----------------------------------
  searchInput.addEventListener("focus", () => {
    dropdown.classList.remove("hidden");
  });

  // -----------------------------------
  // LIVE SEARCH
  // -----------------------------------
  searchInput.addEventListener("input", function () {

    const value = this.value.toLowerCase();

    const items = dropdown.querySelectorAll(".counselor-option");

    items.forEach(item => {

      const text = item.textContent.toLowerCase();

      if (text.includes(value)) {
        item.style.display = "block";
      } else {
        item.style.display = "none";
      }

    });

    dropdown.classList.remove("hidden");
  });

  // -----------------------------------
  // SELECT COUNSELOR
  // -----------------------------------
  function selectCounselor(id, name, email) {

    selectedCounselor.value = id;

    counselorName.textContent = name;
    counselorEmail.textContent = email;

    selectedCard.classList.remove("hidden");

    searchInput.value = `${name} (${email})`;

    profileLink.href = `/student/recommendation/addcounselor/${id}`;

    dropdown.classList.add("hidden");
  }

  // -----------------------------------
  // CLICK OUTSIDE CLOSES DROPDOWN
  // -----------------------------------
  document.addEventListener("click", function (e) {

    const searchContainer = document.getElementById("searchContainer");

    if (!searchContainer.contains(e.target)) {
      dropdown.classList.add("hidden");
    }

  });

</script>

</body>
</html>