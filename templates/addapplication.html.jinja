<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add Application - Recommendation Form</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href= "/static/styles.css" rel="stylesheet" >
</head>
<body class="bg-gradient-to-b from-emerald-50 to-emerald-100 min-h-screen flex flex-col">
{% include "components/navbar.html.jinja" %}
<main class="flex-grow flex items-center justify-center mb-10 mt-10">
  <div class="bg-white shadow-xl rounded-2xl w-full max-w-4xl p-8">
    
    <h2 class="text-2xl font-bold text-gray-800 mb-6">
      Add Application for {{ applicant["FirstName"] }}
    </h2>

    <form method="post" class="space-y-8" action="/counselor/recommendation/addapplication/adding">

      <!-- Application Information -->
      <div>
        <h3 class="text-lg font-semibold text-gray-700 mb-4">
          Application Details
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">
              Given Major to student
            </label>
            <input name="Major" type="text" placeholder="Ex. Journalism, Astology, etc." required
              class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-indigo-500 focus:outline-none">
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">
              Application Type
            </label>
            <select name="Type" required
              class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-indigo-500 focus:outline-none">
              <option>Undergraduate</option>
              <option>Graduate</option>
              <option>Scholarship</option>
              <option>Internship</option>
            </select>
          </div>

        </div>
      </div>

      <!-- Additional Instructions -->
      <div>
        <h3 class="text-lg font-semibold text-gray-700 mb-4">
          Additional comments
        </h3>

        <textarea name="Comments" rows="4" required
          placeholder="Tell your students any kind of recommendations! You can also add any specific instructions for your students here."
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-indigo-500 focus:outline-none"></textarea>
      </div>

      <!-- Submission -->
      <div class="flex justify-end gap-4 pt-4">
        <button type="reset"
          class="px-6 py-2 rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-100 transition">
          Clear
        </button>

        <button type="submit"
          class="px-6 py-2 rounded-lg bg-emerald-600 text-white hover:bg-emerald-700 transition shadow-md">
          Save Application
        </button>
      </div>

    </form>

  </div>
  </main>
{% include "components/footer.html.jinja" %}
</body>
</html>
