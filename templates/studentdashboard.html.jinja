<!doctype html>
<html>

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
  <title>CourseTrack - Dashboard</title>
  <link href="/static/styles.css" rel="stylesheet">
</head>

<body class="bg-gradient-to-b from-emerald-50 to-emerald-100 min-h-screen flex flex-col">
  {% include "components/navbar.html.jinja" %}

  <main class="flex-grow flex justify-center px-6 py-12">
    <div class="w-full max-w-4xl">

      <!-- Header Section -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-emerald-900">
          Welcome back, {{ current_user.name }}
        </h1>

        {% with messages = get_flashed_messages(with_categories=true) %}
          {% if messages %}
            <div class="mb-6 space-y-3">

              {% for category, message in messages %}

                <div class="px-4 py-3 rounded-xl text-sm font-medium shadow-sm border
                  {% if category == 'danger' %}
                    bg-red-100 text-red-700 border-red-200
                  {% elif category == 'warning' %}
                    bg-yellow-100 text-yellow-700 border-yellow-200
                  {% elif category == 'success' %}
                    bg-emerald-100 text-emerald-700 border-emerald-200
                  {% else %}
                    bg-blue-100 text-blue-700 border-blue-200
                  {% endif %}
                ">
                  {{ message }}
                </div>

              {% endfor %}

            </div>
          {% endif %}
        {% endwith %}

        <p class="text-emerald-700 mt-2">
          Grade {{ student.grade }} Student Dashboard
        </p>
      </div>

      <!-- Today's Overview -->
      <div class="bg-white rounded-xl shadow-lg p-6 border border-emerald-100 mb-6">
        <h2 class="text-xl font-semibold text-emerald-800 mb-4">
          Counselor Decision Overview: {{ counselor_decision }}
          <br>
    
      
      
    {% if counselor_id %}
    Your counselor - 
      <a href="{{ url_for('counselor_profile', counselor_id=counselor_id) }}"
        class="text-emerald-600 underline">
        {{ counselor_name }}
      </a>
    {% else %}
      <span class="text-gray-400">No counselor assigned</span>
    {% endif %}
          
         
        </h2>
      </div>



      <!-- Counselor Editing Permission -->
      <div class="bg-white rounded-xl shadow-lg p-6 border border-emerald-100 mb-6">
        <h2 class="text-xl font-semibold text-emerald-800 mb-4">
          Counselor Editing Permission
        </h2>

        <p class="text-sm text-gray-600 mb-3">
          Allow your counselor to edit your academic transcript.
        </p>

        <form method="POST" action="/student/toggle_counselor_edit">
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" name="allow_edit" value="1" {% if student.AllowCounselorEdit %}checked{% endif %}
              class="w-5 h-5 text-emerald-600 border-gray-300 rounded focus:ring-emerald-500">
            <span class="text-sm text-gray-700">Allow counselor to edit my transcript</span>
          </label>

          <button type="submit"
            class="mt-4 px-4 py-2 bg-emerald-600 text-white rounded hover:bg-emerald-700 transition">
            Save
          </button>
        </form>
      </div>

    <!-- Find Your Major Section -->
    <div class="bg-white rounded-xl shadow-lg p-6 border border-emerald-100 mb-6 text-center">

      <h2 class="text-xl font-semibold text-emerald-800 mb-3">
        Explore Your Future
      </h2>

      {% if major_result %}
        
        <!-- USER HAS RESULTS -->
        <p class="text-sm text-gray-600 mb-4">
          You already completed the major finder. View your personalized results below.
        </p>

        <a href="/student/dashboard/find-major/result/{{ major_result.id }}"
          class="inline-block px-5 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition">
          View My Results
        </a>

        <div class="mt-3">
          <a href="/student/dashboard/find-major"
            class="text-sm text-emerald-600 underline hover:text-emerald-800">
            Retake quiz
          </a>
        </div>

      {% else %}

        <!-- USER HAS NO RESULTS -->
        <p class="text-sm text-gray-600 mb-4">
          Not sure what career fits you? Discover majors that match your interests.
        </p>

        <a href="/student/dashboard/find-major"
          class="inline-block px-5 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition">
          Find your major here!
        </a>

      {% endif %}

    </div>
    </div>
  </main>




  {% include "components/footer.html.jinja" %}

  

</body>

</html>