<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
    <title>CourseTrack - Register</title>
    <link href= "/static/styles.css" rel="stylesheet" >
  </head>
<body class="min-h-screen bg-gradient-to-br from-emerald-100 to-emerald-200 flex items-center justify-center p-6">

  <form method="POST" class="bg-white p-10 rounded-2xl shadow-xl w-full max-w-md space-y-6">

    <h2 class="text-3xl font-bold text-emerald-800 text-center">
      Create Account
    </h2>

    <!-- Full Name -->
    <input name="name" type="text" placeholder="Full Name" required class="w-full px-4 py-3 border border-emerald-200 rounded-lg
           focus:outline-none focus:ring-2 focus:ring-emerald-500" />

    <!-- Email -->
    <input name="email" type="email" placeholder="Email" required class="w-full px-4 py-3 border border-emerald-200 rounded-lg
           focus:outline-none focus:ring-2 focus:ring-emerald-500" />

    <!-- Password -->
    <input name="password" type="password" placeholder="Password" required class="w-full px-4 py-3 border border-emerald-200 rounded-lg
           focus:outline-none focus:ring-2 focus:ring-emerald-500" />

    <!-- Role -->
    <div>
      <label class="block mb-2 font-medium text-gray-700">Select Role</label>
      <select name="role" id="role" required class="w-full px-4 py-3 border border-emerald-200 rounded-lg
             focus:outline-none focus:ring-2 focus:ring-emerald-500 bg-white">
        <option value="student">Student</option>
        <option value="counselor">Counselor</option>
      </select>
    </div>

    <!-- STUDENT ONLY SECTION -->
    <div id="studentFields" class="space-y-4">

      <!-- Student Type -->
      <div>
        <label class="block mb-2 font-medium text-gray-700">Student Type</label>
        <select name="student_type" class="w-full px-4 py-3 border border-emerald-200 rounded-lg
               focus:outline-none focus:ring-2 focus:ring-emerald-500 bg-white">
          <option value="High School">High School Student</option>
          <option value="Graduate">Graduate</option>
        </select>
      </div>

      <!-- Grade (only shown if not Graduate) -->
      <div id="gradeSelect">
        <label class="block mb-2 font-medium text-gray-700">Current Grade</label>
        <select name="grade" class="w-full px-4 py-3 border border-emerald-200 rounded-lg
               focus:outline-none focus:ring-2 focus:ring-emerald-500 bg-white">
          <option value="9">9th Grade</option>
          <option value="10">10th Grade</option>
          <option value="11">11th Grade</option>
          <option value="12">12th Grade</option>
        </select>
      </div>

    </div>

    <!-- Button -->
    <button type="submit" class="w-full py-3 bg-emerald-700 text-white font-semibold rounded-lg
           hover:bg-emerald-800 transition duration-200">
      Sign Up
    </button>

    <p class="text-center text-gray-500 text-sm">
      Already have an account?
      <a href="/login" class="text-emerald-700 font-medium hover:underline">
        Log in
      </a>
    </p>

  </form>

  <script>
    const roleSelect = document.getElementById("role");
    const studentFields = document.getElementById("studentFields");
    const studentType = document.querySelector("[name='student_type']");
    const gradeSelect = document.getElementById("gradeSelect");

    function toggleStudentFields() {
      if (roleSelect.value === "student") {
        studentFields.style.display = "block";
        toggleGradeField();
      } else {
        studentFields.style.display = "none";
      }
    }

    function toggleGradeField() {
      if (studentType.value === "Graduate") {
        gradeSelect.style.display = "none";
      } else {
        gradeSelect.style.display = "block";
      }
    }

    roleSelect.addEventListener("change", toggleStudentFields);
    studentType.addEventListener("change", toggleGradeField);

    toggleStudentFields();
  </script>

</body>

</html>