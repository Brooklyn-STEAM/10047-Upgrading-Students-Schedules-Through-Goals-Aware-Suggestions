<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
    <title>CourseTrack - Recommendations</title>
    <link href= "/static/styles.css" rel="stylesheet" >
  </head>
  <body class="bg-gradient-to-b from-emerald-50 to-emerald-100 min-h-screen flex flex-col">
    {% include "components/navbar.html.jinja" %}
    
    <main class="container mx-auto my-10 px-4 py-8 flex-grow">
      <h1 class="text-3xl font-bold text-center mb-6">Recommendations</h1>
      
      <div class="flex justify-center gap-8">
        <!-- Counselor Recommendation -->
        <div class="bg-white max-w-4xl shadow-md rounded-lg p-6">
          <h2 class="text-2xl font-semibold mb-4">Counselor Recommendation</h2>
          <p class="text-gray-600">It looks like you have you have no counselor that can recommend you a course! You will need to add a counselor in order to see recommended courses.</p>
          <div class="flex justify-center mt-4">
          <a href="/student/recommendation/addcounselor" class="mt-4 inline-block px-6 py-2 text-white bg-emerald-500 rounded hover:bg-emerald-600">Add Counselor</a>
          </div>
        </div>
      </div>

      
    </main>
    {% include "components/footer.html.jinja" %}
  </body>
</html>