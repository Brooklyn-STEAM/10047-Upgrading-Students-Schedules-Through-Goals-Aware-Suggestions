<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
    <title>CourseTrack - Recommendations</title>
    <link href="/static/styles.css" rel="stylesheet">
  </head>

  <body class="bg-gradient-to-br from-emerald-50 via-white to-emerald-100 min-h-screen flex flex-col">
    
    {% include "components/navbar.html.jinja" %}
    
    <main class="container mx-auto my-12 px-4 flex-grow">

  <!-- Header -->
  <div class="text-center mb-12">
    <h1 class="text-4xl font-extrabold text-emerald-700 mb-3">
      Your Applications
    </h1>
    <p class="text-gray-500 text-lg">
      Guidance from your counselor will appear here
    </p>
  </div>

  {% if not counselor_id %}
  <!-- ❌ NO COUNSELOR -->
  <div class="flex justify-center">
    <div class="bg-white shadow-xl rounded-2xl p-10 text-center max-w-md border border-emerald-100">
      
      <h2 class="text-2xl font-bold text-gray-800 mb-3">
        No Counselor has given you applications yet
      </h2>

      <p class="text-gray-500 mb-6">
        Add one to start receiving applications.
      </p>

      <div class="flex justify-center gap-4 flex-wrap">        
        <a href="/student/recommendation/editrecommendations"
          class="px-6 py-3 bg-emerald-500 text-white rounded-xl hover:bg-emerald-600 hover:scale-105 transition transform">
          Your Recommendation
        </a>
      </div>

    </div>
  </div>

  {% else %}

    {% if information and information|length > 0 %}

      <!-- ✅ SHOW RECOMMENDATIONS -->
      {% for x in information %}
      <div class="max-w-3xl mx-auto bg-white shadow-xl rounded-2xl p-8 mb-8">

        <div class="mb-4">
          <p class="text-sm text-gray-400">Sent From</p>
          <h2 class="text-lg font-semibold text-gray-800">{{ x['Name'] }}</h2>
        </div>

        <div class="mb-4">
          <h3 class="font-semibold text-emerald-700">📚 Major</h3>
          <p>{{ x['Major'] }}</p>
        </div>

        <div class="mb-4">
          <h3 class="font-semibold text-emerald-700">📝 Comments</h3>
          <p>{{ x['Comments'] }}</p>
        </div>

        <p class="text-sm text-gray-400">Sent on {{ x['Date'] }}</p>
      </div>
      {% endfor %}

      <div class="text-center">
      <a href="/student/recommendation/editrecommendations"
         class="px-6 py-3 bg-emerald-500 text-white rounded-xl hover:bg-emerald-600 hover:scale-105 transition transform">
        Your Recommendation
      </a>
      </div>

    {% else %}

      <!-- ⚠️ NO RECOMMENDATIONS YET -->
      <div class="max-w-2xl mx-auto text-center bg-white shadow-lg rounded-2xl p-10">
        
        <h2 class="text-2xl font-bold text-emerald-700 mb-3">
          No Recommendations Yet
        </h2>

        <p class="text-gray-500 mb-6">
          You haven't created any recommendations yet.
        </p>
        <a href="/student/recommendation/addcounselor"
            class="px-6 py-3 bg-emerald-500 text-white rounded-xl">
            + Add Recommendation
        </a>
  
      </div>

    {% endif %}

  {% endif %}

</main>