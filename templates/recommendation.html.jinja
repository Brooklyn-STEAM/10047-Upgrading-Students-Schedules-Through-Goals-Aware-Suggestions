<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <script src="https://unpkg.com/heroicons@2.0.18/24/outline/index.js"></script>
  <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
  <title>CourseTrack - Recommendations</title>
  <link href="/static/styles.css" rel="stylesheet">
</head>

<body class="bg-gradient-to-br from-emerald-50 via-white to-emerald-100 min-h-screen flex flex-col">

{% include "components/navbar.html.jinja" %}

<main class="w-full max-w-[1200px] mx-auto px-6 py-14 flex-grow">

  <!-- HEADER -->
  <div class="mb-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-2 flex items-center gap-3">
      📄 Your Applications
    </h1>
    <p class="text-gray-500 text-lg">
      Track what your counselor has recommended for you
    </p>
  </div>

  {% if not counselor_id %}

  <!-- NO COUNSELOR -->
  <div class="flex justify-center">
    <div class="bg-white shadow-lg rounded-2xl p-10 text-center max-w-md border border-gray-200">
      
      <div class="mb-4 text-emerald-500 text-5xl">👤</div>

      <h2 class="text-2xl font-bold text-gray-800 mb-3">
        No Counselor Assigned
      </h2>

      <p class="text-gray-500 mb-6">
        Connect with a counselor to start receiving applications.
      </p>

      <a href="/student/recommendation/addcounselor"
         class="inline-flex items-center gap-2 px-6 py-3 bg-emerald-500 text-white rounded-xl hover:bg-emerald-600 transition">
        ➕ Add Counselor
      </a>

    </div>
  </div>

  {% else %}

    {% if information and information|length > 0 %}

    <!-- APPLICATION FEED -->
    <div class="space-y-6">

      {% for x in information %}
      <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition">

        <!-- TOP -->
        <div class="flex justify-between items-start mb-4">
          
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 flex items-center justify-center rounded-full bg-emerald-200 text-emerald-700 font-semibold">
              {{ x['Name'][0] }}
            </div>
            <div>
              <p class="font-semibold text-gray-800">
                {{ x['Name'] }}
              </p>
              <p class="text-xs text-gray-400 flex items-center gap-1">
                👨‍🏫 Counselor
              </p>
            </div>
          </div>

          <!-- Title -->
          <h2 class="text-2xl font-bold text-center text-gray-800 mb-4">
            Counselor & Recommendations
          </h2>

          {% if counselor_id %}

            <p class="text-center text-gray-600 mb-6">
              You are connected with a counselor and can start chatting or reviewing recommendations.
            </p>

            <!-- Buttons -->
            <div class="flex flex-col sm:flex-row justify-center gap-4">

              <a href="/student/recommendation/addcounselor"
                 class="px-6 py-3 text-white bg-emerald-500 rounded-xl shadow-md hover:bg-emerald-600 hover:scale-105 transition transform text-center">
                ➕ Change Counselor
              </a>


            <a href="{{ url_for('chat', user_id=counselor_id) }}"
          class="px-6 py-3 text-white bg-blue-500 rounded-xl shadow-md hover:bg-blue-600 hover:scale-105 transition transform text-center">
              💬 Chat with Counselor
            </a>




              <a href="/student/recommendation/editrecommendations"
                 class="px-6 py-3 text-emerald-600 border border-emerald-500 rounded-xl hover:bg-emerald-50 hover:scale-105 transition transform text-center">
                🔍 Review Recommendations
              </a>

            </div>

          {% else %}

            <p class="text-gray-500 text-center leading-relaxed mb-8">
              It looks like you don’t have a counselor connected yet.
              Add one to start receiving personalized guidance.
            </p>

            <div class="flex flex-col sm:flex-row justify-center gap-4">

              <a href="/student/recommendation/addcounselor"
                 class="px-6 py-3 text-white bg-emerald-500 rounded-xl shadow-md hover:bg-emerald-600 hover:scale-105 transition transform text-center">
                ➕ Add Counselor
              </a>

              <span class="px-6 py-3 text-gray-400 border border-gray-300 rounded-xl text-center">
                💬 Chat unavailable
              </span>

              <a href="/student/recommendation/editrecommendations"
                 class="px-6 py-3 text-emerald-600 border border-emerald-500 rounded-xl hover:bg-emerald-50 hover:scale-105 transition transform text-center">
                🔍 Review Recommendations
              </a>

            </div>

          {% endif %}
          <span class="text-xs text-gray-400 flex items-center gap-1">
            📅 {{ x['Date'] }}
          </span>

        </div>

        <!-- CONTENT -->
        <div class="grid md:grid-cols-2 gap-6">

          <!-- MAJOR -->
          <div>
            <p class="text-xs text-gray-400 mb-1 flex items-center gap-1">
              🎓 Recommended Major
            </p>
            <h3 class="text-lg font-semibold text-emerald-700">
              {{ x['Major'] }}
            </h3>
          </div>

          <!-- COMMENTS -->
          <div>
            <p class="text-xs text-gray-400 mb-1 flex items-center gap-1">
              💬 Comments
            </p>
            <p class="text-sm text-gray-600 leading-relaxed">
              {{ x['Comments'] }}
            </p>
          </div>

        </div>

      </div>
      {% endfor %}

    </div>

    <!-- ACTION -->
    <div class="mt-12 text-center">
      <a href="/student/recommendation/editrecommendations"
         class="inline-flex items-center gap-2 px-6 py-3 bg-emerald-500 text-white rounded-xl hover:bg-emerald-600 hover:scale-105 transition">
        ✏️ Manage Your Recommendation
      </a>
    </div>

    {% else %}

    <!-- EMPTY -->
    <div class="flex justify-center">
      <div class="bg-white border border-gray-200 shadow-lg rounded-2xl p-10 text-center max-w-lg">

        <div class="text-5xl mb-4">📭</div>

        <h2 class="text-2xl font-bold text-gray-800 mb-3">
          No Applications Yet
        </h2>

        <p class="text-gray-500 mb-6">
          Your counselor hasn’t submitted any recommendations yet.
        </p>

        <a href="/student/recommendation/editrecommendations"
           class="inline-flex items-center gap-2 px-6 py-3 bg-emerald-500 text-white rounded-xl hover:bg-emerald-600 transition">
          📌 View Your Request
        </a>

      </div>
    </div>

    {% endif %}

  {% endif %}

</main>

{% include "components/footer.html.jinja" %}

</body>
</html>