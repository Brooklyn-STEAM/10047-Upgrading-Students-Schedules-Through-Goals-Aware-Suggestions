<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
    <title>CourseTrack - Recommendation</title>
    <link href="/static/styles.css" rel="stylesheet">
  </head>
  <body class="bg-emerald-100 min-h-screen flex flex-col">

    {% include "components/navbar.html.jinja" %}

    {% if user %}
    <div class="max-w-6xl mx-auto bg-white/90 backdrop-blur shadow-2xl rounded-2xl flex-grow p-8 mt-12 mb-12 border border-emerald-100">
      
      <!-- Header Section -->
      <div class="flex justify-between items-center mb-8">
        <div>
          <h1 class="text-3xl font-extrabold text-emerald-700">Student Applications</h1>
          <p class="text-gray-500 text-sm mt-1">Manage and review student requests</p>
        </div>
        <span class="bg-emerald-100 text-emerald-700 px-4 py-1 rounded-full text-sm font-medium">
          {{ user|length }} Students
        </span>
      </div>

      <!-- Table -->
      <div class="overflow-x-auto rounded-xl border border-gray-200">
        <table class="min-w-full overflow-hidden">
          
          <!-- Table Head -->
          <thead class="bg-emerald-100 text-gray-700 uppercase text-sm">
            <tr>
              <th class="py-3 px-4 text-left">ID</th>
              <th class="py-3 px-4 text-left">Name</th>
              <th class="py-3 px-4 text-left">Grade</th>
              <th class="py-3 px-4 text-left">Message</th>
              <th class="py-3 px-4 text-center">Action</th>
            </tr>
          </thead>

          <!-- Table Body -->
          <tbody class="text-gray-700">
            {% for x in user %}
            <tr class="border-t odd:bg-white even:bg-gray-50 hover:bg-emerald-50 transition">
              
              <td class="py-3 px-4 font-medium text-gray-800">
                #{{ x['ID'] }}
              </td>

              <td class="py-3 px-4">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 flex items-center justify-center bg-emerald-200 text-emerald-700 rounded-full font-semibold">
                    {{ x['Name'][0] }}
                  </div>
                  <span class="font-medium">{{ x['Name'] }}</span>
                </div>
              </td>

              <td class="py-3 px-4">
                <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-xs font-semibold">
                  Grade {{ x['Grade'] }}
                </span>
              </td>

              <td class="py-3 px-4 max-w-xs truncate">
                {{ x.get('Comments') or "No message provided" }}
              </td>

              <td class="py-3 px-4 text-center">
                <a href="/counselor/recommendation/addapplication/{{ x['UserID'] }}" 
                   class="inline-block px-4 py-2 text-sm font-semibold text-white bg-emerald-500 rounded-lg shadow hover:bg-emerald-600 hover:scale-105 transition transform">
                  + Add
                </a>
              </td>

            </tr>
            {% endfor %}
          </tbody>

        </table>
      </div>

    </div>

    {% else %}
    <div class="flex-grow flex items-center justify-center px-6 py-20">
      <div class="bg-white shadow-xl rounded-2xl p-12 text-center max-w-md border border-emerald-100">

        <!-- Icon -->
        <div class="flex justify-center mb-6">
          <div class="bg-emerald-100 p-4 rounded-full">
            <svg xmlns="http://www.w3.org/2000/svg" 
                 class="h-10 w-10 text-emerald-500" 
                 fill="none" 
                 viewBox="0 0 24 24" 
                 stroke="currentColor">
              <path stroke-linecap="round" 
                    stroke-linejoin="round" 
                    stroke-width="2" 
                    d="M9 12h6m-6 4h6M7 4h10a2 2 0 012 2v14l-5-3-5 3V6a2 2 0 012-2z"/>
            </svg>
          </div>
        </div>

        <!-- Message -->
        <h2 class="text-2xl font-bold text-gray-800 mb-3">
          No Applications Available
        </h2>

        <p class="text-gray-500 leading-relaxed">
          There are currently no students assigned to you.<br>
          Once students connect with you, they will appear here.
        </p>

      </div>
    </div>
    {% endif %}

    {% include "components/footer.html.jinja" %}
  </body>
</html>