<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
    <title>CourseTrack - Recommendation</title>
    <link href= "/static/styles.css" rel="stylesheet" >
  </head>
  <body class="bg-gradient-to-b from-emerald-50 to-emerald-100 min-h-screen flex flex-col">
    {% include "components/navbar.html.jinja" %}


{%if user%}
   <div class="max-w-6xl mx-auto bg-white shadow-lg rounded-lg flex-grow p-6 mt-10 mb-10">
    
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold text-gray-800">Student Applications</h1>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
      <table class="min-w-full border border-gray-200 rounded-lg overflow-hidden">
        
        <!-- Table Head -->
        <thead class="bg-green-200 text-gray-700 uppercase text-sm">
          <tr>
            <th class="py-3 px-4 text-left">ID</th>
            <th class="py-3 px-4 text-left">Name</th>
            <th class="py-3 px-4 text-left">Last Name</th>
            <th class="py-3 px-4 text-left">Grade</th>
            <th class="py-3 px-4 text-left">Message</th>
            <th></th>
          </tr>
        </thead>

        <!-- Table Body -->
        <tbody class="text-gray-700">
        {%for x in user%}
            <tr class="border-t hover:bg-gray-50">
                <td class="py-3 px-4">{{x['ID']}}</td>
                <td class="py-3 px-4">{{x['FirstName']}}</td>
                <td class="py-3 px-4">{{x['LastName']}}</td>
                <td class="py-3 px-4">{{x['Grade']}}</td>
                <td class="py-3 px-4">{{x['Comments']}}</td>
                <td class="py-3 px-4">
                <div>
                    <a href="/counselor/recommendation/addapplication/{{x['ID']}}" class="text-white bg-emerald-400 p-2 hover:bg-emerald-500 rounded">Add Application</a>
                </div>
                </td>
          </tr>
        {%endfor%}
      </table>
    </div>

  </div>
{% else %}
<div class="flex-grow flex items-center justify-center px-6 py-16">
  <div class="bg-white shadow-lg rounded-lg p-10 text-center max-w-md border border-emerald-100">

    <!-- Icon -->
    <div class="flex justify-center mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" 
           class="h-12 w-12 text-emerald-400" 
           fill="none" 
           viewBox="0 0 24 24" 
           stroke="currentColor">
        <path stroke-linecap="round" 
              stroke-linejoin="round" 
              stroke-width="2" 
              d="M9 12h6m-6 4h6M7 4h10a2 2 0 012 2v14l-5-3-5 3V6a2 2 0 012-2z"/>
      </svg>
    </div>

    <!-- Message -->
    <h2 class="text-xl font-semibold text-gray-800 mb-2">
      No Applications to Assign
    </h2>

    <p class="text-gray-600">
      There are currently no students that require an application assignment.
    </p>

  </div>
</div>
{% endif %}

    {% include "components/footer.html.jinja" %}
  </body>
</html>