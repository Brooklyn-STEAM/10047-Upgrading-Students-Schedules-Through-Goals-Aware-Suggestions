<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
  <title>CourseTrack - Counselor Recommendation</title>
  <link href="/static/styles.css" rel="stylesheet">
</head>

<body class="bg-gradient-to-br from-emerald-50 via-white to-emerald-100 min-h-screen flex flex-col">

{% include "components/navbar.html.jinja" %}

<main class="w-full max-w-[1400px] mx-auto px-6 py-12 flex-grow">

  <!-- HEADER -->
  <div class="flex justify-between items-center mb-10">
    <div>
      <h1 class="text-4xl font-bold text-gray-900">Your Students</h1>
      <p class="text-gray-500 mt-1">Manage applications and track student progress</p>
    </div>

    <div class="bg-emerald-100 text-emerald-700 px-4 py-2 rounded-xl font-medium">
      {{ user|length }} Student{{ user|length != 1 and 's' or '' }}
    </div>
  </div>

  <!-- TABLE -->
  <div class="bg-white shadow-xl rounded-2xl border border-gray-200 overflow-hidden">
    
    <table class="w-full table-auto">
      
      <!-- HEAD -->
      <thead class="bg-gray-50 text-gray-600 text-sm uppercase tracking-wide">
        <tr>
          <th class="px-6 py-4 text-left">Student</th>
          <th class="px-6 py-4 text-left">Grade</th>
          <th class="px-6 py-4 text-left">Applications</th>
          <th class="px-6 py-4 text-center">Action</th>
        </tr>
      </thead>

      <tbody>
      {% for x in user %}

      <!-- MAIN ROW -->
      <tr onclick="toggleRow('{{ x['ID'] }}')"
          class="cursor-pointer border-t hover:bg-emerald-50 transition">

        <!-- STUDENT -->
        <td class="px-6 py-4">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 flex items-center justify-center rounded-full bg-emerald-200 text-emerald-700 font-semibold">
              {{ x['StudentName'][0] }}
            </div>

            <div>
              <p class="font-semibold text-gray-800">
                {{ x['StudentName'] }}
              </p>
              <p class="text-sm text-gray-400">
                {{ x['StudentEmail'] }}
              </p>
            </div>
          </div>
        </td>

        <!-- GRADE -->
        <td class="px-6 py-4">
          <span class="px-3 py-1 text-xs font-semibold bg-blue-100 text-blue-700 rounded-full">
            Grade {{ x['Grade'] }}
          </span>
        </td>

        <!-- APPLICATION COUNT -->
        <td class="px-6 py-4">
          {% if x['application_count'] > 0 %}
            <span class="px-3 py-1 text-xs font-semibold bg-emerald-100 text-emerald-700 rounded-full">
              {{ x['application_count'] }} Application{{ x['application_count'] != 1 and 's' or '' }}
            </span>
          {% else %}
            <span class="px-3 py-1 text-xs font-semibold bg-gray-100 text-gray-500 rounded-full">
              No Applications
            </span>
          {% endif %}
        </td>

        <!-- ACTION -->
        <td class="px-6 py-4 text-center">
          <div class="flex justify-center gap-2">

            <!-- Add Application -->
            <a href="/counselor/recommendation/addapplication/{{ x['UserID'] }}" 
              onclick="event.stopPropagation();"
              class="px-3 py-2 bg-emerald-500 text-white text-sm rounded-lg hover:bg-emerald-600">
              + Add
            </a>

            <!-- Chat -->
            <a href="{{ url_for('chat', user_id=x['UserID']) }}"
              onclick="event.stopPropagation();"
              class="px-3 py-2 bg-emerald-500 text-white text-sm rounded-lg hover:bg-emerald-600">
              Chat
            </a>

            <!-- 🔥 NEW: Remove Student -->
            <a href="/counselor/dashboard/decline/{{ x['UserID'] }}"
              onclick="event.stopPropagation();"
              class="px-3 py-2 bg-red-500 text-white text-sm rounded-lg hover:bg-red-600">
              Remove
            </a>

          </div>
        </td>

      </tr>

      <!-- EXPANDABLE ROW -->
      <tr>
        <td colspan="4" class="p-0">

          <div id="row-{{ x['ID'] }}"
               class="overflow-hidden max-h-0 opacity-0 transition-all duration-500 ease-in-out bg-gray-50">

            <div class="p-6 flex gap-10">

              <!-- LEFT -->
              <div class="w-[350px] space-y-4">
                <div>
                  <p class="text-xs text-gray-400">Student Info</p>
                  <p class="font-semibold text-gray-800">{{ x['StudentName'] }}</p>
                  <p class="text-sm text-gray-500">{{ x['StudentEmail'] }}</p>
                </div>

                <div>
                  <p class="text-xs text-gray-400">Grade</p>
                  <p class="font-medium">Grade {{ x['Grade'] }}</p>
                </div>

                <div>
                  <p class="text-xs text-gray-400">Notes</p>
                  <p class="text-sm text-gray-600">
                    {{ x.get('Comments') or "No notes provided" }}
                  </p>
                </div>
              </div>

              <!-- RIGHT -->
              <div class="flex-1">

                {% if x['applications'] %}

                <div class="relative">

                  {% for app in x['applications'] %}
                  <div class="app-slide-{{ x['ID'] }} {% if not loop.first %}hidden{% endif %}">

                    <!-- VIEW -->
                    <div id="view-{{ app['ID'] }}" class="bg-white border rounded-xl p-5 shadow-sm">

                      <p class="text-xs text-gray-400">Major</p>
                      <h3 class="font-semibold text-gray-800">{{ app['Major'] }}</h3>

                      <p class="text-xs text-gray-400 mt-3">Comments</p>
                      <p class="text-sm text-gray-600">{{ app['Comments'] }}</p>

                      <div class="flex justify-between items-center mt-3">
                        <span class="text-xs text-gray-400">{{ app['Date'] }}</span>

                        <div class="flex gap-2">
                          <button onclick="toggleEdit('{{ app['ID'] }}')"
                                  class="px-3 py-1 text-xs bg-gray-100 rounded-lg">
                            Edit
                          </button>

                          <form action="/counselor/recommendation/delete/{{ app['ID'] }}" method="POST">
                            <button type="submit"
                                    class="px-3 py-1 text-xs bg-red-100 text-red-600 rounded-lg">
                              Delete
                            </button>
                          </form>
                        </div>
                      </div>

                    </div>

                    <!-- EDIT -->
                    <form id="edit-{{ app['ID'] }}"
                          action="/counselor/recommendation/edit/{{ app['ID'] }}"
                          method="POST"
                          class="hidden bg-white border rounded-xl p-5 space-y-3">

                      <input name="major" value="{{ app['Major'] }}"
                             class="w-full px-3 py-2 border rounded-lg">

                      <textarea name="comments"
                                class="w-full px-3 py-2 border rounded-lg">{{ app['Comments'] }}</textarea>

                      <div class="flex justify-end gap-2">
                        <button type="button" onclick="toggleEdit('{{ app['ID'] }}')">Cancel</button>
                        <button type="submit"
                                class="px-4 py-1 bg-emerald-500 text-white rounded-lg">
                          Save
                        </button>
                      </div>

                    </form>

                  </div>
                  {% endfor %}

                  <!-- NAV -->
                  <div class="flex justify-between mt-4">
                    <button onclick="prevApp('{{ x['ID'] }}')">←</button>
                    <span id="app-index-{{ x['ID'] }}">1</span>
                    <button onclick="nextApp('{{ x['ID'] }}')">→</button>
                  </div>

                </div>

                {% else %}
                  <p class="text-gray-400 text-sm">No applications submitted yet</p>
                {% endif %}

              </div>

            </div>

          </div>

        </td>
      </tr>

      {% endfor %}
      </tbody>

    </table>

  </div>

</main>

{% include "components/footer.html.jinja" %}

<script>
function toggleRow(id) {
  const el = document.getElementById("row-" + id);

  document.querySelectorAll("[id^='row-']").forEach(row => {
    if (row.id !== "row-" + id) {
      row.classList.add("max-h-0", "opacity-0");
      row.classList.remove("max-h-[500px]", "opacity-100");
    }
  });

  el.classList.toggle("max-h-[500px]");
  el.classList.toggle("opacity-100");
  el.classList.toggle("max-h-0");
  el.classList.toggle("opacity-0");
}

function toggleEdit(id) {
  document.getElementById("view-" + id).classList.toggle("hidden");
  document.getElementById("edit-" + id).classList.toggle("hidden");
}

const appIndex = {};

function showApp(studentId, index) {
  const slides = document.querySelectorAll(".app-slide-" + studentId);
  slides.forEach((el, i) => el.classList.toggle("hidden", i !== index));
  appIndex[studentId] = index;
  document.getElementById("app-index-" + studentId).innerText = index + 1;
}

function nextApp(id) {
  const slides = document.querySelectorAll(".app-slide-" + id);
  let i = (appIndex[id] ?? 0) + 1;
  showApp(id, i % slides.length);
}

function prevApp(id) {
  const slides = document.querySelectorAll(".app-slide-" + id);
  let i = (appIndex[id] ?? 0) - 1;
  showApp(id, (i + slides.length) % slides.length);
}
</script>

</body>
</html>