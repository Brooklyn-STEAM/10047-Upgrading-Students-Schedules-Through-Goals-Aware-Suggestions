<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
  <title>Chat</title>
  <link href="/static/styles.css" rel="stylesheet">
</head>

<body class="bg-white min-h-screen flex flex-col">

{% include "components/navbar.html.jinja" %}

<!-- FULL SCREEN CHAT WRAPPER -->
<div class="flex flex-col h-[calc(100vh-64px)]"> 
<!-- adjust 64px if your navbar is different -->

  <!-- HEADER (Instagram DM style) -->
  <div class="flex items-center justify-between px-5 py-4 border-b bg-white shadow-sm">
    <div>
      <h2 class="text-lg font-semibold text-gray-900"> {{ receiver_name }} </h2>
      <p class="text-xs text-gray-500">Direct Messages</p>
    </div>
  </div>

  <!-- MESSAGES AREA (FULL HEIGHT SCROLL) -->
  <div id="chat-box"
       class="flex-1 overflow-y-auto px-4 py-6 space-y-3 bg-gray-50">

  </div>

  <!-- INPUT BAR (STICKY BOTTOM LIKE INSTAGRAM) -->
  <div class="border-t bg-white px-4 py-3 flex items-center gap-3">

    <input 
      id="message-input"
      type="text"
      placeholder="Message..."
      class="flex-1 px-4 py-2 rounded-full border focus:outline-none focus:ring-2 focus:ring-emerald-400"
    />

    <button 
      onclick="sendMessage()"
      class="bg-emerald-500 text-white px-5 py-2 rounded-full hover:bg-emerald-600 transition">
      Send
    </button>

  </div>

</div>


<script>
const receiverId = {{ receiver_id }};
const currentUserId = {{ current_user.id }};

let lastMessageId = 0;

// RESET when page loads (IMPORTANT)
function resetChat() {
    document.getElementById("chat-box").innerHTML = "";
    lastMessageId = 0;
}

// Load messages
async function loadMessages() {
    const res = await fetch(`/get_messages/${receiverId}`);
    const messages = await res.json();

    const chatBox = document.getElementById("chat-box");

    messages.forEach(msg => {

        if (msg.ID > lastMessageId) {

            const isMe = msg.SenderID == currentUserId;

            const wrapper = document.createElement("div");
            wrapper.className = `flex items-end gap-2 ${isMe ? "justify-end" : "justify-start"}`;

            const img = document.createElement("img");
            img.className = "w-8 h-8 rounded-full object-cover";

            img.src = msg.SenderProfilePicture
                ? `/static/profile_pics/${msg.SenderProfilePicture}`
                : "https://ui-avatars.com/api/?name=" + encodeURIComponent(msg.SenderName);

            const bubble = document.createElement("div");
            bubble.className = `
                max-w-[70%] px-4 py-2 text-sm shadow-sm
                ${isMe
                    ? "bg-emerald-500 text-white rounded-2xl rounded-br-md"
                    : "bg-white text-gray-800 border rounded-2xl rounded-bl-md"}
            `;

            bubble.textContent = msg.Content;

            if (isMe) {
                wrapper.appendChild(bubble);
                wrapper.appendChild(img);
            } else {
                wrapper.appendChild(img);
                wrapper.appendChild(bubble);
            }

            chatBox.appendChild(wrapper);

            lastMessageId = msg.ID;
        }
    });

    chatBox.scrollTop = chatBox.scrollHeight;
}

// Send message
async function sendMessage() {
    const input = document.getElementById("message-input");

    const text = input.value.trim();
    if (!text) return;

    input.value = "";

    await fetch("/send_message", {
        method: "POST",
        headers: {"Content-Type": "application/x-www-form-urlencoded"},
        body: `receiver_id=${receiverId}&content=${encodeURIComponent(text)}`
    });

    loadMessages();
}

// Enter key
document.getElementById("message-input").addEventListener("keypress", function(e) {
    if (e.key === "Enter") sendMessage();
});

// INIT
resetChat();
loadMessages();
setInterval(loadMessages, 2000);
</script>

</body>
</html>