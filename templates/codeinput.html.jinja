<!doctype html>
<html class="scroll-smooth">

<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>CourseTrack - Join With Code</title>

  <!-- Tailwind -->
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

  <!-- Icons -->
  <script src="https://unpkg.com/feather-icons"></script>

  <link rel="icon" type="image/png"
        href="{{ url_for('static', filename='images/logo.png') }}">

  <link href="/static/styles.css" rel="stylesheet">

</head>

<body class="min-h-screen bg-gradient-to-br from-emerald-50 via-white to-emerald-100 overflow-x-hidden">
{% include "components/navbar.html.jinja" %}

<!-- BACKGROUND DECOR -->
<div class="fixed top-0 left-0 w-full h-full overflow-hidden -z-10">

  <div class="absolute top-[-100px] left-[-100px]
              w-[350px] h-[350px]
              bg-emerald-300/30 rounded-full blur-3xl">
  </div>

  <div class="absolute bottom-[-120px] right-[-120px]
              w-[400px] h-[400px]
              bg-emerald-200/40 rounded-full blur-3xl">
  </div>

</div>

<!-- PAGE -->
<div class="min-h-screen flex items-center justify-center px-6 py-20">

  <div class="w-full max-w-6xl grid lg:grid-cols-2 gap-16 items-center">

    <!-- LEFT SIDE -->
    <div class="space-y-8">

      <!-- LOGO -->
      <div class="flex items-center gap-4">

        <div class="bg-emerald-800 p-4 rounded-3xl shadow-lg">

          <img
            src="{{ url_for('static', filename='images/logo.png') }}"
            class="w-12 h-12"
            alt="CourseTrack Logo">

        </div>

        <div>

          <h1 class="text-4xl font-black text-emerald-900">
            CourseTrack
          </h1>

          <p class="text-emerald-700 text-lg">
            Student Registration Portal
          </p>

        </div>

      </div>

      <!-- BIG TEXT -->
      <div class="space-y-6">

        <h2 class="text-6xl leading-tight font-black text-gray-900">

          Connect with your counselor instantly.

        </h2>

        <p class="text-xl leading-relaxed text-gray-600 max-w-xl">

          Create your student account using your counselor’s private access code
          and get connected immediately for academic guidance, planning,
          and recommendations.

        </p>

      </div>

      <!-- FEATURE LIST -->
      <div class="space-y-5 pt-6">

        <div class="flex items-start gap-4">

          <div class="bg-emerald-100 p-2 rounded-xl">
            <i data-feather="check"
               class="w-5 h-5 text-emerald-700"></i>
          </div>

          <div>

            <h3 class="font-bold text-gray-800 text-lg">
              Instant Counselor Connection
            </h3>

            <p class="text-gray-500">
              Your account is automatically linked after registration.
            </p>

          </div>

        </div>

        <div class="flex items-start gap-4">

          <div class="bg-emerald-100 p-2 rounded-xl">
            <i data-feather="shield"
               class="w-5 h-5 text-emerald-700"></i>
          </div>

          <div>

            <h3 class="font-bold text-gray-800 text-lg">
              Secure Student Access
            </h3>

            <p class="text-gray-500">
              Only students with valid counselor invitation codes may register.
            </p>

          </div>

        </div>

        <div class="flex items-start gap-4">

          <div class="bg-emerald-100 p-2 rounded-xl">
            <i data-feather="book-open"
               class="w-5 h-5 text-emerald-700"></i>
          </div>

          <div>

            <h3 class="font-bold text-gray-800 text-lg">
              Personalized Academic Guidance
            </h3>

            <p class="text-gray-500">
              Get course support, recommendations, and future planning assistance.
            </p>

          </div>

        </div>

      </div>

    </div>

    <!-- RIGHT SIDE -->
    <div>

      <form
        method="POST"
        action="/register/code"
        class="bg-white/80 backdrop-blur-xl border border-white/40
               rounded-[2rem] shadow-2xl p-10 md:p-14">

        <!-- HEADER -->
        <div class="mb-10">

          <div class="bg-emerald-100 w-16 h-16 rounded-2xl
                      flex items-center justify-center shadow-md mb-6">

            <i data-feather="user-plus"
               class="w-8 h-8 text-emerald-700"></i>

          </div>

          <h2 class="text-4xl font-black text-gray-900">
            Create Account
          </h2>

          <p class="mt-3 text-gray-500 text-lg leading-relaxed">
            Fill in your information below to begin your academic journey.
          </p>

        </div>

        <!-- FLASH -->
        {% with messages = get_flashed_messages(with_categories=true) %}
          {% if messages %}

            <div class="mb-8 space-y-4">

              {% for category, message in messages %}

                <div class="
                  px-5 py-4 rounded-2xl border text-sm font-medium

                  {% if category == 'danger' %}
                    bg-red-100 text-red-700 border-red-200
                  {% elif category == 'success' %}
                    bg-emerald-100 text-emerald-700 border-emerald-200
                  {% elif category == 'warning' %}
                    bg-yellow-100 text-yellow-700 border-yellow-200
                  {% else %}
                    bg-gray-100 text-gray-700 border-gray-200
                  {% endif %}
                ">
                  {{ message }}
                </div>

              {% endfor %}

            </div>

          {% endif %}
        {% endwith %}

        <!-- FORM GRID -->
        <div class="space-y-7">

          <!-- NAME -->
          <div>

            <label class="block text-sm font-bold text-gray-700 mb-3">
              Full Name
            </label>

            <input
              type="text"
              name="name"
              required
              placeholder="John Doe"
              class="w-full px-5 py-4 rounded-2xl border border-emerald-200
                     focus:outline-none focus:ring-4 focus:ring-emerald-200
                     text-lg bg-white">

          </div>

          <!-- EMAIL -->
          <div>

            <label class="block text-sm font-bold text-gray-700 mb-3">
              Email Address
            </label>

            <input
              type="email"
              name="email"
              required
              placeholder="student@email.com"
              class="w-full px-5 py-4 rounded-2xl border border-emerald-200
                     focus:outline-none focus:ring-4 focus:ring-emerald-200
                     text-lg bg-white">

          </div>

          <!-- PASSWORD -->
          <div>

            <label class="block text-sm font-bold text-gray-700 mb-3">
              Password
            </label>

            <input
              type="password"
              name="password"
              required
              placeholder="Create password"
              class="w-full px-5 py-4 rounded-2xl border border-emerald-200
                     focus:outline-none focus:ring-4 focus:ring-emerald-200
                     text-lg bg-white">

          </div>

          <!-- CONFIRM PASSWORD -->
        <div>

        <label class="block text-sm font-bold text-gray-700 mb-3">
            Confirm Password
        </label>

        <input
            type="password"
            name="confirm_password"
            required
            placeholder="Confirm password"
            class="w-full px-5 py-4 rounded-2xl border border-emerald-200
                focus:outline-none focus:ring-4 focus:ring-emerald-200
                text-lg bg-white">

        </div>

          <!-- STUDENT TYPE -->
          <div class="grid md:grid-cols-2 gap-6">

            <div>

              <label class="block text-sm font-bold text-gray-700 mb-3">
                Student Type
              </label>

              <select
                name="student_type"
                id="student_type"
                class="w-full px-5 py-4 rounded-2xl border border-emerald-200
                       focus:outline-none focus:ring-4 focus:ring-emerald-200
                       bg-white text-lg">

                <option value="High School">High School</option>
                <option value="Graduate">Graduate</option>

              </select>

            </div>

            <div id="gradeSelect">

              <label class="block text-sm font-bold text-gray-700 mb-3">
                Grade
              </label>

              <select
                name="grade"
                class="w-full px-5 py-4 rounded-2xl border border-emerald-200
                       focus:outline-none focus:ring-4 focus:ring-emerald-200
                       bg-white text-lg">

                <option value="9">9th Grade</option>
                <option value="10">10th Grade</option>
                <option value="11">11th Grade</option>
                <option value="12">12th Grade</option>

              </select>

            </div>

          </div>

          <!-- CODE -->
          <div class="pt-4">

            <label class="block text-sm font-bold text-gray-700 mb-3">
              Counselor Access Code
            </label>

            <input
              type="text"
              name="code"
              required
              maxlength="8"
              placeholder="ENTER CODE"
              class="w-full px-5 py-5 rounded-2xl border border-emerald-300
                     text-center uppercase tracking-[0.4em]
                     text-2xl font-black text-emerald-700
                     focus:outline-none focus:ring-4 focus:ring-emerald-200
                     bg-emerald-50">

          </div>

          <!-- BUTTON -->
          <button
            type="submit"
            class="w-full py-5 mt-4 rounded-2xl
                   bg-gradient-to-r from-emerald-700 to-emerald-500
                   text-white text-lg font-bold
                   shadow-xl hover:shadow-2xl
                   hover:scale-[1.02]
                   transition-all duration-300">

            Create Account & Connect

          </button>

        </div>

        <!-- LOGIN -->
        <div class="mt-10 text-center">

          <p class="text-gray-500">

            Already have an account?

            <a href="/login"
               class="text-emerald-700 font-bold hover:underline">

              Log in

            </a>

          </p>

        </div>

      </form>

    </div>

  </div>

</div>
{% include "components/footer.html.jinja" %}
<script>

  feather.replace()

  const studentType = document.getElementById("student_type")
  const gradeSelect = document.getElementById("gradeSelect")

  function toggleGradeField() {

    if (studentType.value === "Graduate") {

      gradeSelect.style.display = "none"

    } else {

      gradeSelect.style.display = "block"

    }

  }

  studentType.addEventListener("change", toggleGradeField)

  toggleGradeField()

</script>

</body>
</html>