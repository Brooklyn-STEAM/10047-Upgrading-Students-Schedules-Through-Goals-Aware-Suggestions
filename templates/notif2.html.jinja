<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
  <title>Counselor Notifications - CourseTrack</title>
  <link href="/static/styles.css" rel="stylesheet">
</head>

<body class="bg-gradient-to-br from-emerald-50 via-white to-emerald-100 min-h-screen flex flex-col">

{% include "components/navbar.html.jinja" %}

<main class="w-full max-w-3xl mx-auto px-6 py-14 flex-grow">

  <!-- HEADER -->
  <div class="mb-10 flex justify-between items-center">
    <h1 class="text-3xl font-bold text-gray-900">
      📢 Counselor Notifications
    </h1>

    <a href="/counselor/dashboard"
       class="text-sm text-emerald-600 hover:underline">
      ← Back
    </a>
  </div>

  {% if notifications and notifications|length > 0 %}

  <div class="space-y-4">

    {% for n in notifications %}
    <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm hover:shadow-md transition">

      <!-- Top row -->
      <div class="flex justify-between items-center mb-2">

        <p class="font-semibold text-gray-800">
          {{ n['StudentName'] }}
        </p>

        <span class="text-xs px-2 py-1 rounded-full
          {% if n['Type'] == 'accepted' %}
            bg-green-100 text-green-700
          {% elif n['Type'] == 'declined' %}
            bg-red-100 text-red-600
          {% else %}
            bg-gray-100 text-gray-600
          {% endif %}
        ">
          {{ n['Type']|capitalize }}
        </span>

      </div>

      <!-- Message -->
      <p class="text-sm text-gray-600">
        {{ n['Message'] }}
      </p>

      <!-- Optional extra info -->
      {% if n['Major'] %}
      <p class="text-sm text-emerald-700 mt-2">
        <span class="font-medium">Requested Major:</span> {{ n['Major'] }}
      </p>
      {% endif %}

      <!-- Date -->
      <p class="text-xs text-gray-400 mt-3">
        {{ n['Date'].strftime("%B %d, %Y at %I:%M %p") }}
      </p>

    </div>
    {% endfor %}

  </div>

  {% else %}

  <!-- EMPTY STATE -->
  <div class="text-center mt-20">
    <div class="text-5xl mb-4">🔕</div>
    <h2 class="text-xl font-semibold text-gray-800 mb-2">
      No Notifications
    </h2>
    <p class="text-gray-500">
      You’re all caught up!
    </p>
  </div>

  {% endif %}

</main>

{% include "components/footer.html.jinja" %}

</body>
</html>