<!doctype html>
<html class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Notifications - CourseTrack</title>
  <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link href="/static/styles.css" rel="stylesheet">
</head>

<body class="bg-gradient-to-br from-emerald-50 via-white to-emerald-100 min-h-screen flex flex-col">

{% include "components/navbar.html.jinja" %}

<main class="w-full max-w-3xl mx-auto px-6 py-14 flex-grow">

  <!-- HEADER -->
  <div class="mb-10 flex justify-between items-center">
    <h1 class="text-3xl font-bold text-gray-900">
      🔔 Notifications
    </h1>

    <a href="/student/recommendation"
       class="text-sm text-emerald-600 hover:underline">
      ← Back
    </a>
  </div>

{% if (notifications and notifications|length > 0) or (message_notifications and message_notifications|length > 0) %}
  <div class="space-y-4">
  <!-- 💬 MESSAGE NOTIFICATIONS -->
{% if message_notifications and message_notifications|length > 0 %}

<div class="mb-8">
  <h2 class="text-lg font-semibold text-gray-800 mb-3">
    💬 New Messages
  </h2>

  <div class="space-y-3">

    {% for msg in message_notifications %}

    <a href="/chat/{{ msg['SenderID'] }}"
       class="block rounded-xl p-5 shadow-sm hover:shadow-md transition border bg-blue-50 border-blue-200">

      <div class="flex justify-between items-center mb-1">

        <p class="font-semibold text-gray-800">
          {{ msg['SenderName'] }}
        </p>

        <span class="text-xs bg-blue-500 text-white px-2 py-0.5 rounded-full">
          {{ msg['Count'] }}
        </span>

      </div>

      <p class="text-sm text-gray-700">
        Sent you {{ msg['Count'] }} new message{{ 's' if msg['Count'] > 1 else '' }}
      </p>

      <p class="text-xs text-gray-400 mt-2">
        {{ msg['LastMessageTime'] }}
      </p>

    </a>

    {% endfor %}

  </div>
</div>

{% endif %}

    {% for n in notifications %}

    <div
       class="block rounded-xl p-5 shadow-sm hover:shadow-md transition border

       {% if n['Source'] == 'declined' %}
         bg-red-50 border-red-200
       {% elif n['Type'] == 'accepted' %}
         bg-green-50 border-green-200
       {% else %}
         bg-white border-gray-200
       {% endif %}
    ">

      <!-- Top -->
      <div class="flex justify-between items-center mb-2">

        <p class="font-semibold text-gray-800">
          {% if n['Source'] == 'declined' %}
            Counselor
          {% else %}
            {{ n.get('CounselorName', 'Counselor') }}
          {% endif %}
        </p>

        {% if n['Source'] == 'declined' %}
          <span class="text-xs text-red-600 font-medium">Declined</span>
        {% elif n['Type'] == 'accepted' %}
          <span class="text-xs text-green-600 font-medium">Accepted</span>
        {% else %}
          <span class="text-xs text-gray-500 font-medium">
            {{ n['Type'] | capitalize }}
          </span>
        {% endif %}

      </div>

      <!-- Message -->
      <p class="text-sm text-gray-700 leading-relaxed">
        {{ n['Message'] }}
      </p>

      <!-- Timestamp -->
      {% if n['CreatedAt'] %}
      <p class="text-xs text-gray-400 mt-3">
        {{ n['CreatedAt'].strftime("%B %d, %Y at %I:%M %p") }}
      </p>
      {% endif %}

    </div>

    {% endfor %}

  </div>

  {% else %}

  <!-- EMPTY STATE -->
  <div class="text-center mt-20">
    <div class="text-5xl mb-4">🔕</div>
    <h2 class="text-xl font-semibold text-gray-800 mb-2">
      No Notifications
    </h2>
    <p class="text-gray-500">
      You're all caught up!
    </p>
  </div>

  {% endif %}

</main>

{% include "components/footer.html.jinja" %}

</body>
</html>