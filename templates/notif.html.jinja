<!doctype html>
<html class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Notifications - CourseTrack</title>

  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link href="/static/styles.css" rel="stylesheet">
</head>

<body class="bg-gradient-to-br from-emerald-50 via-white to-emerald-100 min-h-screen flex flex-col">

{% include "components/navbar.html.jinja" %}

<main class="w-full max-w-3xl mx-auto px-6 py-14 flex-grow">

  <!-- HEADER -->
  <div class="mb-10 flex justify-between items-center">
    <h1 class="text-3xl font-bold text-gray-900">
      🔔 Notifications
    </h1>

    <a href="/student/recommendation"
       class="text-sm text-emerald-600 hover:underline">
      ← Back
    </a>
  </div>

  {% if notifications and notifications|length > 0 %}

  <div class="space-y-4">

    {% for n in notifications %}
    <a href="/student/notifications/read/{{ n['ID'] }}"
    class="block bg-white border border-gray-200 rounded-xl p-5 shadow-sm hover:shadow-md transition">

      <!-- Top -->
      <div class="flex justify-between items-center mb-2">
        <p class="font-semibold text-gray-800">
          {{ n['CounselorName'] }}
        </p>
        <span class="text-xs text-red-500 font-medium">
          Declined
        </span>
      </div>

      <!-- Message -->
      <p class="text-sm text-gray-600">
        Your request was declined by <span class="font-medium">{{ n['CounselorName'] }}</span>.
      </p>

      <!-- Reason -->
      {% if n['Reason'] %}
      <div class="mt-3 bg-red-50 border border-red-200 rounded-lg p-3">
        <p class="text-xs text-red-600 mb-1">Reason</p>
        <p class="text-sm text-red-700">
          {{ n['Reason'] }}
        </p>
      </div>
      {% endif %}

    </a>
    {% endfor %}

  </div>

  {% else %}

  <!-- EMPTY STATE -->
  <div class="text-center mt-20">
    <div class="text-5xl mb-4">🔕</div>
    <h2 class="text-xl font-semibold text-gray-800 mb-2">
      No Notifications
    </h2>
    <p class="text-gray-500">
      You're all caught up!
    </p>
  </div>

  {% endif %}

</main>

{% include "components/footer.html.jinja" %}

</body>
</html>