        function showFlash(message, category = "success") {
            const container = document.getElementById("flashContainer");

            const styles = {
                success: "bg-emerald-100 text-emerald-800 border border-emerald-300",
                danger: "bg-red-100 text-red-800 border border-red-300",
                warning: "bg-yellow-100 text-yellow-800 border border-yellow-300",
                info: "bg-gray-100 text-gray-800 border border-gray-300"
            };

            const div = document.createElement("div");
            div.className = `px-4 py-3 rounded-lg text-sm font-medium shadow ${styles[category] || styles.info}`;
            div.innerText = message;

            container.appendChild(div);

            // Auto-dismiss ONLY for success/info
            if (category === "success" || category === "info") {
                setTimeout(() => {
                    div.style.opacity = "0";
                    div.style.transition = "opacity 0.5s";
                    setTimeout(() => div.remove(), 500);
                }, 2500);
            }
        }




        function getCoursesForCategory(category) {
            if (!selectedCurriculum || !courseOptions[selectedCurriculum]) return [];
            if (!courseOptions[selectedCurriculum][category]) return [];

            const block = courseOptions[selectedCurriculum][category];
            const list = block.high_school || [];

            if (!list.includes("Other")) {
                return [...list, "Other"];
            }

            return list;
        }

        // Select a student from the list
        function selectStudent(studentUserId, studentName, allowEditFlag) {
            currentStudentId = studentUserId;
            currentStudentCanEdit = !!allowEditFlag;
            editMode = false;

            // Reset UI
            document.getElementById("noSelection").classList.add("hidden");
            document.getElementById("transcriptWrapper").classList.remove("hidden");
            document.getElementById("studentHeader").classList.remove("hidden");
            document.getElementById("transcriptContainer").innerHTML = "";
            document.getElementById("overallGpa").innerText = "N/A";

            // Reset recommendation panel
            const recPanel = document.getElementById("recommendationPanel");
            const recBtn = document.getElementById("viewRecsBtn");
            if (recPanel) {
                recPanel.classList.add("hidden");
                recPanel.innerHTML = `<p class="text-gray-500">Recommendations will appear here after loading.</p>`;
            }
            if (recBtn) {
                recBtn.disabled = false;
                recBtn.innerText = "View Student Recommendations";
