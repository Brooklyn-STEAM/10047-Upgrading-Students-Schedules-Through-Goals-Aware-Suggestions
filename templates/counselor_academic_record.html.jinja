                        </tbody>
                    </table>
                </div>

                <button class="mt-2 bg-blue-600 hover:bg-blue-700 text-white text-xs px-3 py-1 rounded edit-only hidden"
                        onclick="addRow(${g.GradeLevel})">
                    + Add Subject
                </button>

                <div class="mt-2 font-semibold text-sm">
                    GPA: <span id="gpa-${g.GradeLevel}">0.00</span>
                </div>
            </div>
        `;

                container.appendChild(section);

                const tbody = section.querySelector(`#gradeBody-${g.GradeLevel}`);

                g.Subjects.forEach(sub => {
                    addRow(g.GradeLevel);

                    const row = tbody.lastElementChild;

                    const categorySelect = row.querySelector(".categorySelect");
                    const courseSelect = row.querySelector(".courseSelect");
                    const customInput = row.querySelector(".customCourseInput");
                    const marksInput = row.querySelector(".marksInput");
                    const letterInput = row.querySelector(".letterInput");
                    const creditsInput = row.querySelector(".creditsInput");
                    const prefSelect = row.querySelector(".preferenceSelect");

                    categorySelect.value = sub.MainCategory || "";
                    onCategoryChangeCounselor(categorySelect, g.GradeLevel);

                    courseSelect.value = sub.CourseName || "";

                    if (sub.CourseName === "Other") {
                        customInput.classList.remove("hidden");
                        customInput.value = sub.CustomCourseName || sub.Name || "";
                    } else {
                        customInput.classList.add("hidden");
                        customInput.value = "";
                    }

                    marksInput.value = sub.Marks ?? "";
                    letterInput.value = sub.Letter ?? "";
                    creditsInput.value = sub.Credits ?? "";
                    prefSelect.value = sub.Preference ?? "";
                });

                updateGPA(g.GradeLevel);
            });

            applyEditModeToDOM();
        }



        // Toggle edit mode (only if allowed)
        function toggleEditMode() {
            if (!currentStudentCanEdit) return;

            editMode = !editMode;
            document.getElementById("toggleEditBtn").innerText =
                editMode ? "Disable Edit" : "Enable Edit";

            const saveBtn = document.getElementById("saveBtn");
            if (editMode) {
                saveBtn.classList.remove("hidden");
            } else {
                saveBtn.classList.add("hidden");
            }

            applyEditModeToDOM();
        }

        // Apply edit mode to all relevant elements
        function applyEditModeToDOM() {
            const editOnlyElems = document.querySelectorAll(".edit-only");
            editOnlyElems.forEach(el => {
                if (editMode && currentStudentCanEdit) {
                    el.classList.remove("hidden");
                } else {
                    el.classList.add("hidden");
                }
            });

            const elements = document.querySelectorAll(
                "#transcriptContainer tbody tr td input, #transcriptContainer tbody tr td select"
            );

            elements.forEach(el => {
                const td = el.closest("td");
                if (!td) return;

                const col = td.cellIndex;

                const isMarksField = col === 2;
                const isLetterField = col === 3;

                // Letter is ALWAYS readonly
                if (isLetterField) {
                    el.readOnly = true;
                    el.disabled = false;
                    el.classList.add("bg-gray-100");
                    return;
                }

                // Marks must be editable in edit mode
                if (isMarksField) {
                    if (editMode && currentStudentCanEdit) {
                        el.readOnly = false;
                        el.disabled = false;
                        el.classList.remove("bg-gray-50");
                    } else {
                        el.readOnly = true;
                        el.classList.add("bg-gray-50");
                    }
                    return;
                }

                // All other fields follow normal edit rules
                if (!editMode || !currentStudentCanEdit) {
                    if (el.tagName === "SELECT") {
                        el.disabled = true;
                    } else {
                        el.readOnly = true;
                    }
                    el.classList.add("bg-gray-50");
                } else {
                    if (el.tagName === "SELECT") {
                        el.disabled = false;
                    } else {
                        el.readOnly = false;
                    }
                    el.classList.remove("bg-gray-50");
                }
            });
        }

