<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CourseTrack - Counselor Academic Records</title>
    <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-b from-emerald-50 to-emerald-100 min-h-screen flex flex-col">
    <div id="top"></div>

    {% include "components/navbar.html.jinja" %}
    <div class="flex-grow">
        <div class="container mx-auto my-6 px-4 max-w-6xl">
            <h1 class="text-2xl font-bold mb-4">My Students' Academic Records</h1>

            <div class="flex flex-col md:flex-row gap-4">
                <!-- Students list -->
                <div class="md:w-1/3 bg-white shadow-md rounded-lg p-4 max-h-[70vh] overflow-y-auto">
                    <h2 class="text-lg font-semibold mb-3">Students</h2>

                    {% if students %}
                    <ul id="studentList" class="space-y-2">
                        {% for s in students %}
                        <li>
                            <button
                                class="w-full text-left border border-gray-200 rounded-md px-3 py-2 hover:bg-emerald-50 transition"
                                onclick="selectStudent({{ s.StudentUserID }}, '{{ s.StudentName|e }}', {{ 1 if s.AllowEdit else 0 }})">
                                <div class="flex justify-between items-center">
                                    <div>
                                        <div class="font-medium">{{ s.StudentName }}</div>
                                        <div class="text-xs text-gray-500">{{ s.StudentEmail }}</div>
                                        <div class="text-xs text-gray-500">
                                            Grade: {{ s.Grade if s.Grade is not none else 'N/A' }} |
                                            Type: {{ s.StudentType }}
                                        </div>
                                    </div>
                                    <span
                                        class="text-xs px-2 py-1 rounded
                                        {% if s.AllowEdit %} bg-green-100 text-green-700 {% else %} bg-gray-100 text-gray-500 {% endif %}">
                                        {% if s.AllowEdit %}Edit allowed{% else %}View only{% endif %}
                                    </span>
                                </div>
                            </button>
                        </li>
                        {% endfor %}
                    </ul>
                    {% else %}
                    <p class="text-sm text-gray-600">No students assigned yet.</p>
                    {% endif %}
                </div>

                <!-- Transcript viewer -->
                <div class="md:w-2/3 bg-white shadow-md rounded-lg p-4">
                    <div id="studentHeader" class="mb-4 hidden">
                        <div class="flex justify-between items-center">
                            <div>
                                <h2 id="studentName" class="text-xl font-semibold"></h2>
                                <p id="studentMeta" class="text-sm text-gray-600"></p>
                            </div>
                            <div>
                                <span id="editStatusBadge" class="text-xs px-2 py-1 rounded bg-gray-100 text-gray-500">
                                </span>
                            </div>
                        </div>
                    </div>

                    <div id="noSelection" class="text-gray-500 text-sm">
                        Select a student from the left to view their transcript.
                    </div>

                    <div id="transcriptWrapper" class="hidden">
                        <!-- Controls -->
                        <div class="flex justify-end gap-2 mb-3">
                            <button id="toggleEditBtn"
                                class="hidden bg-blue-600 hover:bg-blue-700 text-white text-sm px-3 py-1 rounded"
                                onclick="toggleEditMode()">
                                Enable Edit
                            </button>
                            <button id="saveBtn"
                                class="hidden bg-green-700 hover:bg-green-800 text-white text-sm px-3 py-1 rounded"
                                onclick="saveCounselorChanges()">
                                Save Changes
                            </button>
                        </div>

                        <!-- Transcript container -->
                        <div id="transcriptContainer" class="space-y-4"></div>

                        <!-- Overall GPA -->
                        <div class="mt-4 font-semibold">
                            Overall GPA: <span id="overallGpa">N/A</span>
                        </div>

                        <!-- Recommendation Viewer -->
                        <div class="mt-6">
                            <button id="viewRecsBtn"
                                class="bg-emerald-700 hover:bg-emerald-800 text-white text-sm px-4 py-2 rounded"
                                onclick="loadStudentRecommendations()">
                                View Student Recommendations
                            </button>

                            <div id="recommendationPanel"
                                class="hidden mt-4 p-4 bg-emerald-50 border border-emerald-200 rounded-lg text-sm text-gray-800">
                                <p class="text-gray-500">Recommendations will appear here after loading.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {% include "components/footer.html.jinja" %}

    <script>
        // Global state
        let currentStudentId = null;
        let currentStudentCanEdit = false;
        let editMode = false;
        let currentTranscript = null; // store loaded transcript

        const courseOptions = {
            "Math": [
                "General Math", "Mathematics", "Integrated Math", "Integrated Math I", "Integrated Math II", "Integrated Math III",
                "Algebra I", "Algebra II", "Linear Algebra",
                "Geometry", "Advanced Geometry",
                "Trigonometry", "Pre-Calculus", "Functions & Relations",
                "Calculus", "AP Calculus AB", "AP Calculus BC",
                "Statistics", "AP Statistics", "Data Analysis",
                "Higher Maths", "Further Maths", "Additional Mathematics", "Pure Mathematics", "Applied Mathematics",
                "Mathematical Methods", "Specialist Mathematics",
                "Cambridge IGCSE Mathematics", "Cambridge Additional Mathematics",
                "CBSE Mathematics", "ICSE Mathematics",
                "Other"
            ],
            "Science": [
                "General Science", "Integrated Science", "Physical Science", "Life Science",
                "Biology", "Advanced Biology", "AP Biology", "IB Biology SL", "IB Biology HL",
                "Chemistry", "Advanced Chemistry", "AP Chemistry", "IB Chemistry SL", "IB Chemistry HL",
                "Physics", "Advanced Physics", "AP Physics 1", "AP Physics 2",
                "AP Physics C: Mechanics", "AP Physics C: Electricity & Magnetism",
                "IB Physics SL", "IB Physics HL",
                "Environmental Science", "AP Environmental Science", "Earth Science", "Marine Science",
                "Home Science", "Food Science", "Health Science", "Agricultural Science",
                "Cambridge IGCSE Biology", "Cambridge IGCSE Chemistry", "Cambridge IGCSE Physics",
                "CBSE Science", "ICSE Science",
                "Other"
            ],
            "English / Language Arts": [
                "English", "English Language Arts (ELA)", "English Literature", "English Composition",
                "English 1st Paper", "English 2nd Paper",
                "English 9", "English 10", "English 11", "English 12",
                "AP English Language", "AP English Literature",
                "IB English A: Language & Literature SL", "IB English A: Language & Literature HL",
                "IB English A: Literature SL", "IB English A: Literature HL",
                "Cambridge IGCSE English", "Cambridge IGCSE Literature",
                "CBSE English", "ICSE English",
                "Other"
            ],
            "Social Studies / Humanities": [
                "History", "World History", "US History", "European History",
                "AP World History", "AP US History", "AP European History",
                "Geography", "Civics", "Government", "Political Science",
                "Sociology", "Psychology",
                "Economics", "AP Microeconomics", "AP Macroeconomics",
                "IB History SL", "IB History HL", "IB Economics SL", "IB Economics HL",
                "Cambridge IGCSE History", "Cambridge IGCSE Geography",
                "CBSE Social Science", "ICSE History & Civics",
                "Other"
            ],
            "Computer Science / Technology": [
                "Computer Science", "Information Technology", "Programming",
                "Web Development", "Software Development",
                "AP Computer Science A", "AP Computer Science Principles",
                "IB Computer Science SL", "IB Computer Science HL",
                "Data Science", "Robotics", "Artificial Intelligence",
                "Digital Literacy",
                "Cambridge IGCSE Computer Science",
                "CBSE Computer Applications", "ICSE Computer Studies",
                "Other"
            ],
            "Business / Commerce": [
                "Business Studies", "Accounting", "Finance", "Marketing", "Entrepreneurship",
                "Economics", "AP Microeconomics", "AP Macroeconomics",
                "IB Business Management SL", "IB Business Management HL",
                "Cambridge IGCSE Business Studies", "Cambridge IGCSE Accounting",
                "CBSE Business Studies", "ICSE Commercial Studies",
                "Other"
            ],
            "Arts": [
                "Visual Arts", "Fine Arts", "Music", "Drama", "Theatre",
                "Photography", "Graphic Design", "Digital Media",
                "AP Art & Design",
                "IB Visual Arts SL", "IB Visual Arts HL",
                "Cambridge IGCSE Art & Design",
                "Other"
            ],
            "Foreign Language": [
                "Spanish", "French", "German", "Mandarin", "Arabic",
                "Hindi", "Bengali", "Urdu", "Japanese", "Korean",
                "Latin", "Greek",
                "AP Spanish", "AP French",
                "IB Language B SL", "IB Language B HL",
                "Cambridge IGCSE Languages",
                "Other"
            ],
            "Physical Education / Health": [
                "Physical Education", "Health", "Sports Science", "Fitness", "Yoga",
                "IB Sports, Exercise & Health Science",
                "Cambridge IGCSE Physical Education",
                "Other"
            ],
            "Other": [
                "Other"
            ]
        };

        const mainCategories = Object.keys(courseOptions);

        // Select a student from the list
        function selectStudent(studentUserId, studentName, allowEditFlag) {
            currentStudentId = studentUserId;
            currentStudentCanEdit = !!allowEditFlag;
            editMode = false;

            // Reset UI
            document.getElementById("noSelection").classList.add("hidden");
            document.getElementById("transcriptWrapper").classList.remove("hidden");
            document.getElementById("studentHeader").classList.remove("hidden");
            document.getElementById("transcriptContainer").innerHTML = "";
            document.getElementById("overallGpa").innerText = "N/A";

            // Reset recommendation panel
            const recPanel = document.getElementById("recommendationPanel");
            const recBtn = document.getElementById("viewRecsBtn");
            if (recPanel) {
                recPanel.classList.add("hidden");
                recPanel.innerHTML = `<p class="text-gray-500">Recommendations will appear here after loading.</p>`;
            }
            if (recBtn) {
                recBtn.disabled = false;
                recBtn.innerText = "View Student Recommendations";
            }

            // Header
            document.getElementById("studentName").innerText = studentName;
            document.getElementById("studentMeta").innerText = "";
            const badge = document.getElementById("editStatusBadge");
            const toggleEditBtn = document.getElementById("toggleEditBtn");
            const saveBtn = document.getElementById("saveBtn");

            if (currentStudentCanEdit) {
                badge.innerText = "Edit allowed";
                badge.className = "text-xs px-2 py-1 rounded bg-green-100 text-green-700";
                toggleEditBtn.classList.remove("hidden");
                saveBtn.classList.add("hidden");
                toggleEditBtn.innerText = "Enable Edit";
            } else {
                badge.innerText = "View only";
                badge.className = "text-xs px-2 py-1 rounded bg-gray-100 text-gray-500";
                toggleEditBtn.classList.add("hidden");
                saveBtn.classList.add("hidden");
            }

            // Fetch transcript
            fetch(`/counselor/student_transcript/${studentUserId}`)
                .then(res => res.json())
                .then(data => {
                    currentTranscript = data.transcript;
                    // Show profile meta
                    if (data.profile) {
                        const grade = data.profile.Grade ?? "N/A";
                        const type = data.profile.StudentType ?? "N/A";
                        document.getElementById("studentMeta").innerText =
                            `Grade: ${grade} | Type: ${type}`;
                    }

                    renderTranscript(data.transcript);
                })
                .catch(err => {
                    console.error(err);
                    alert("Error loading transcript.");
                });
        }

        // Render transcript into the container (read-only by default)
        function renderTranscript(transcript) {
            const container = document.getElementById("transcriptContainer");
            container.innerHTML = "";

            if (!transcript || !transcript.Grades || transcript.Grades.length === 0) {
                container.innerHTML = "<p class='text-sm text-gray-500'>No transcript available for this student.</p>";
                document.getElementById("overallGpa").innerText = "N/A";
                return;
            }

            // Overall GPA
            document.getElementById("overallGpa").innerText =
                transcript.GPA != null ? parseFloat(transcript.GPA).toFixed(2) : "N/A";

            // For each grade level
            transcript.Grades.sort((a, b) => a.GradeLevel - b.GradeLevel);
            transcript.Grades.forEach(g => {
                const section = document.createElement("div");
                section.className = "border border-gray-200 rounded-md";

                section.innerHTML = `
                    <div class="flex justify-between items-center bg-green-600 text-white px-4 py-2 font-bold">
                        <span>Grade ${g.GradeLevel}</span>
                    </div>
                    <div class="bg-white rounded-b-md p-3">
                        <div class="overflow-x-auto">
                            <table class="min-w-full border border-gray-200 text-sm">
                                <thead class="bg-gray-100">
                                    <tr>
                                        <th class="px-3 py-2 text-left">Category</th>
                                        <th class="px-3 py-2 text-left">Course</th>
                                        <th class="px-3 py-2 text-left">Marks (%)</th>
                                        <th class="px-3 py-2 text-left">Letter</th>
                                        <th class="px-3 py-2 text-left">Credits</th>
                                        <th class="px-3 py-2 text-left">Preference</th>
                                        <th class="px-3 py-2 text-left edit-only hidden">Remove</th>
                                    </tr>
                                </thead>

                                <tbody id="gradeBody-${g.GradeLevel}">
                                </tbody>
                            </table>
                        </div>
                        <button class="mt-2 bg-blue-600 hover:bg-blue-700 text-white text-xs px-3 py-1 rounded edit-only hidden"
                                onclick="addRow(${g.GradeLevel})">
                            + Add Subject
                        </button>
                        <div class="mt-2 font-semibold text-sm">
                            GPA: <span id="gpa-${g.GradeLevel}">0.00</span>
                        </div>
                    </div>
                `;

                container.appendChild(section);

                const tbody = section.querySelector(`#gradeBody-${g.GradeLevel}`);

                // Fill subjects
                g.Subjects.forEach(sub => {
                    const row = document.createElement("tr");

                    let courseList = [];
                    if (sub.MainCategory && courseOptions[sub.MainCategory]) {
                        courseList = courseOptions[sub.MainCategory];
                    }

                    const courseOptionsHtml = ['<option value="">Select course</option>']
                        .concat(courseList.map(c => `
            <option value="${c}" ${sub.CourseName === c ? "selected" : ""}>${c}</option>
        `))
                        .join("");

                    const isOther = sub.CourseName === "Other";
                    const customName = sub.CustomCourseName || (isOther ? (sub.Name || "") : "");

                    row.innerHTML = `
                                    <!-- Category -->
                                    <td class="border px-3 py-2">
                                        <select class="categorySelect w-full border rounded p-1"
                                                onchange="onCategoryChangeCounselor(this, ${g.GradeLevel})">
                                            <option value="">Select category</option>
                                            ${mainCategories.map(c => `
                                                <option value="${c}" ${sub.MainCategory === c ? "selected" : ""}>${c}</option>
                                            `).join("")}
                                        </select>
                                    </td>

                                    <!-- Course -->
                                    <td class="border px-3 py-2">
                                        <select class="courseSelect w-full border rounded p-1"
                                                onchange="onCourseChangeCounselor(this, ${g.GradeLevel})">
                                            ${courseOptionsHtml}
                                        </select>
                                        <input class="customCourseInput w-full border rounded p-1 mt-1 ${isOther ? "" : "hidden"}"
                                            placeholder="Enter course name"
                                            value="${customName}">
                                    </td>

                                    <!-- Marks -->
                                    <td class="border px-3 py-2">
                                        <input type="text"
                                            value="${sub.Marks ?? ''}"
                                            oninput="forceNumeric(this); updateGrade(this, ${g.GradeLevel})"
                                            class="marksInput w-full border rounded p-1">
                                    </td>

                                    <!-- Letter -->
                                    <td class="border px-3 py-2">
                                        <input readonly
                                            value="${sub.Letter ?? ''}"
                                            class="letterInput w-full border rounded p-1 bg-gray-100">
                                    </td>

                                    <!-- Credits -->
                                    <td class="border px-3 py-2">
                                        <input type="text"
                                            value="${sub.Credits ?? ''}"
                                            oninput="forceDecimal(this); updateGPA(${g.GradeLevel})"
                                            class="creditsInput w-full border rounded p-1">
                                    </td>

                                    <!-- Preference -->
                                    <td class="border px-3 py-2">
                                        <select class="preferenceSelect w-full border rounded p-1">
                                            <option value="">--</option>
                                            <option value="1" ${sub.Preference == 1 ? "selected" : ""}>1</option>
                                            <option value="2" ${sub.Preference == 2 ? "selected" : ""}>2</option>
                                            <option value="3" ${sub.Preference == 3 ? "selected" : ""}>3</option>
                                            <option value="4" ${sub.Preference == 4 ? "selected" : ""}>4</option>
                                            <option value="5" ${sub.Preference == 5 ? "selected" : ""}>5</option>
                                        </select>
                                    </td>

                                    <!-- Remove -->
                                    <td class="border px-3 py-2 text-center edit-only">
                                        <button class="bg-red-600 text-white px-2 py-1 rounded"
                                                onclick="deleteRow(this, ${g.GradeLevel})">
                                            X
                                        </button>
                                    </td>
                                `;

                    tbody.appendChild(row);
                });

                updateGPA(g.GradeLevel);
            });

            applyEditModeToDOM();
        }

        // Toggle edit mode (only if allowed)
        function toggleEditMode() {
            if (!currentStudentCanEdit) return;

            editMode = !editMode;
            document.getElementById("toggleEditBtn").innerText =
                editMode ? "Disable Edit" : "Enable Edit";

            const saveBtn = document.getElementById("saveBtn");
            if (editMode) {
                saveBtn.classList.remove("hidden");
            } else {
                saveBtn.classList.add("hidden");
            }

            applyEditModeToDOM();
        }

        // Apply edit mode to all relevant elements
        function applyEditModeToDOM() {
            const editOnlyElems = document.querySelectorAll(".edit-only");
            editOnlyElems.forEach(el => {
                if (editMode && currentStudentCanEdit) {
                    el.classList.remove("hidden");
                } else {
                    el.classList.add("hidden");
                }
            });

            const elements = document.querySelectorAll(
                "#transcriptContainer tbody tr td input, #transcriptContainer tbody tr td select"
            );

            elements.forEach(el => {
                const td = el.closest("td");
                if (!td) return;

                const col = td.cellIndex;

                const isMarksField = col === 2;
                const isLetterField = col === 3;

                // Letter is ALWAYS readonly
                if (isLetterField) {
                    el.readOnly = true;
                    el.disabled = false;
                    el.classList.add("bg-gray-100");
                    return;
                }

                // Marks must be editable in edit mode
                if (isMarksField) {
                    if (editMode && currentStudentCanEdit) {
                        el.readOnly = false;
                        el.disabled = false;
                        el.classList.remove("bg-gray-50");
                    } else {
                        el.readOnly = true;
                        el.classList.add("bg-gray-50");
                    }
                    return;
                }

                // All other fields follow normal edit rules
                if (!editMode || !currentStudentCanEdit) {
                    if (el.tagName === "SELECT") {
                        el.disabled = true;
                    } else {
                        el.readOnly = true;
                    }
                    el.classList.add("bg-gray-50");
                } else {
                    if (el.tagName === "SELECT") {
                        el.disabled = false;
                    } else {
                        el.readOnly = false;
                    }
                    el.classList.remove("bg-gray-50");
                }
            });
        }

        // Add a new subject row to a grade
        function addRow(gradeLevel) {
            const tbody = document.querySelector(`#gradeBody-${gradeLevel}`);
            const row = document.createElement("tr");

            row.innerHTML = `
        <!-- Category -->
        <td class="border px-3 py-2">
            <select class="categorySelect w-full border rounded p-1"
                    onchange="onCategoryChangeCounselor(this, ${gradeLevel})">
                <option value="">Select category</option>
                ${mainCategories.map(c => `<option value="${c}">${c}</option>`).join("")}
            </select>
        </td>

        <!-- Course -->
        <td class="border px-3 py-2">
            <select class="courseSelect w-full border rounded p-1"
                    onchange="onCourseChangeCounselor(this, ${gradeLevel})">
                <option value="">Select course</option>
            </select>
            <input class="customCourseInput w-full border rounded p-1 mt-1 hidden"
                   placeholder="Enter course name">
        </td>

        <!-- Marks -->
        <td class="border px-3 py-2">
            <input type="text"
                   oninput="forceNumeric(this); updateGrade(this, ${gradeLevel})"
                   class="marksInput w-full border rounded p-1">
        </td>

        <!-- Letter -->
        <td class="border px-3 py-2">
            <input readonly
                   class="letterInput w-full border rounded p-1 bg-gray-100">
        </td>

        <!-- Credits -->
        <td class="border px-3 py-2">
            <input type="text"
                   oninput="forceDecimal(this); updateGPA(${gradeLevel})"
                   class="creditsInput w-full border rounded p-1">
        </td>

        <!-- Preference -->
        <td class="border px-3 py-2">
            <select class="preferenceSelect w-full border rounded p-1">
                <option value="">--</option>
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4</option>
                <option value="5">5</option>
            </select>
        </td>

        <!-- Remove -->
        <td class="border px-3 py-2 text-center edit-only">
            <button class="bg-red-600 text-white px-2 py-1 rounded"
                    onclick="deleteRow(this, ${gradeLevel})">
                X
            </button>
        </td>
    `;

            tbody.appendChild(row);
        }

        // Calculate letter from marks
        function calculateLetter(mark) {
            if (mark >= 97) return "A+";
            if (mark >= 93) return "A";
            if (mark >= 90) return "A-";
            if (mark >= 87) return "B+";
            if (mark >= 83) return "B";
            if (mark >= 80) return "B-";
            if (mark >= 70) return "C";
            if (mark >= 60) return "D";
            return "F";
        }

        function updateGrade(input, gradeLevel) {
            const row = input.closest("tr");

            // Marks is column 3
            const marks = parseFloat(row.children[2].querySelector("input").value);

            // Letter is column 4
            const letterInput = row.children[3].querySelector("input");

            const letter = calculateLetter(marks);

            letterInput.value = letter;

            updateGPA(gradeLevel);
        }

        function deleteRow(btn, gradeLevel) {
            btn.closest("tr").remove();
            updateGPA(gradeLevel);
        }

        function letterToPoint(letter) {
            const scale = {
                "A+": 4, "A": 4, "A-": 3.7,
                "B+": 3.3, "B": 3, "B-": 2.7,
                "C+": 2.3, "C": 2, "D": 1, "F": 0
            };
            return scale[letter] || 0;
        }

        function updateGPA(gradeLevel) {
            const rows = document.querySelectorAll(`#gradeBody-${gradeLevel} tr`);
            let total = 0, credits = 0;

            rows.forEach(r => {
                const letter = r.children[3].querySelector("input").value || "";
                const cred = parseFloat(r.children[4].querySelector("input").value);

                if (!isNaN(cred) && cred > 0) {
                    total += letterToPoint(letter) * cred;
                    credits += cred;
                }
            });

            const gpa = credits ? (total / credits).toFixed(2) : "0.00";
            document.getElementById(`gpa-${gradeLevel}`).innerText = gpa;

            recomputeOverallGPA();
        }

        function recomputeOverallGPA() {
            const gpaSpans = document.querySelectorAll("[id^='gpa-']");
            let total = 0, count = 0;
            gpaSpans.forEach(span => {
                const val = parseFloat(span.innerText);
                if (!isNaN(val)) {
                    total += val;
                    count++;
                }
            });
            const overall = count ? (total / count).toFixed(2) : "0.00";
            document.getElementById("overallGpa").innerText = overall;
        }

        // Collect data and send to backend
        async function saveCounselorChanges() {
            if (!currentStudentId || !currentStudentCanEdit) return;

            const grades = [];
            const gradeSections = document.querySelectorAll("#transcriptContainer tbody[id^='gradeBody-']");

            gradeSections.forEach(tbody => {
                const gradeLevel = parseInt(tbody.id.replace("gradeBody-", ""));
                const subjects = [];

                // find matching grade in currentTranscript (if any)
                let existingGrade = null;
                if (currentTranscript && Array.isArray(currentTranscript.Grades)) {
                    existingGrade = currentTranscript.Grades.find(g => parseInt(g.GradeLevel) === gradeLevel);
                }

                tbody.querySelectorAll("tr").forEach((row, idx) => {
                    const categorySelect = row.querySelector("td:nth-child(1) select");
                    const courseSelect = row.querySelector("td:nth-child(2) select");
                    const customInput = row.querySelector("td:nth-child(2) input");

                    const marksInput = row.querySelector("td:nth-child(3) input");
                    const letterInput = row.querySelector("td:nth-child(4) input");
                    const creditsInput = row.querySelector("td:nth-child(5) input");
                    const prefSelect = row.querySelector("td:nth-child(6) select");

                    const marks = parseFloat(marksInput.value);
                    const letter = letterInput.value;
                    const credits = parseFloat(creditsInput.value);
                    const preference = parseInt(prefSelect.value);

                    // try to preserve category/course/custom from existing transcript
                    let mainCategory = null;
                    let courseName = null;
                    let customCourseName = null;

                    if (existingGrade && Array.isArray(existingGrade.Subjects) && existingGrade.Subjects[idx]) {
                        const oldSub = existingGrade.Subjects[idx];
                        mainCategory = oldSub.MainCategory ?? null;
                        courseName = oldSub.CourseName ?? null;
                        customCourseName = oldSub.CustomCourseName ?? null;
                    }

                    subjects.push({
                        MainCategory: categorySelect.value || null,
                        CourseName: courseSelect.value || null,
                        CustomCourseName: customInput.classList.contains("hidden")
                            ? null
                            : (customInput.value.trim() || null),

                        Marks: isNaN(marks) ? null : marks,
                        Letter: letter || null,
                        Credits: isNaN(credits) ? null : credits,
                        Preference: isNaN(preference) ? null : preference,

                        // Name = course OR custom course (same as student)
                        Name: customInput.classList.contains("hidden")
                            ? (courseSelect.value || "")
                            : (customInput.value.trim() || "")
                    });
                });

                if (subjects.length > 0) {
                    // Calculate GPA for this grade
                    let total = 0, creditsSum = 0;
                    subjects.forEach(sub => {
                        const point = letterToPoint(sub.Letter);
                        if (sub.Credits) {
                            total += point * sub.Credits;
                            creditsSum += sub.Credits;
                        }
                    });
                    const gpa = creditsSum ? (total / creditsSum).toFixed(2) : 0;

                    grades.push({
                        GradeLevel: gradeLevel,
                        GPA: gpa,
                        Subjects: subjects
                    });
                }
            });

            // Overall GPA
            let total = 0, count = 0;
            grades.forEach(g => {
                total += parseFloat(g.GPA);
                count++;
            });
            const overallGPA = count ? (total / count).toFixed(2) : 0;

            try {
                const res = await fetch(`/counselor/save_transcript/${currentStudentId}`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        GPA: overallGPA,
                        Grades: grades
                    })
                });

                const data = await res.json();
                alert(data.message || "Saved.");

                if (data.status === "success") {
                    editMode = false;
                    document.getElementById("toggleEditBtn").innerText = "Enable Edit";
                    document.getElementById("saveBtn").classList.add("hidden");
                    // reload
                    selectStudent(
                        currentStudentId,
                        document.getElementById("studentName").innerText,
                        currentStudentCanEdit ? 1 : 0
                    );
                }
            } catch (err) {
                console.error(err);
                alert("Error saving transcript.");
            }
        }

        function onCategoryChangeCounselor(select, gradeLevel) {
            const row = select.closest("tr");
            const courseSelect = row.querySelector("td:nth-child(2) select");
            const customInput = row.querySelector("td:nth-child(2) input");

            courseSelect.innerHTML = `<option value="">Select course</option>`;
            customInput.classList.add("hidden");
            customInput.value = "";

            const category = select.value;
            if (!category || !courseOptions[category]) return;

            courseOptions[category].forEach(c => {
                courseSelect.innerHTML += `<option value="${c}">${c}</option>`;
            });
        }

        function onCourseChangeCounselor(select, gradeLevel) {
            const row = select.closest("tr");
            const customInput = row.querySelector("td:nth-child(2) input");
            const course = select.value;

            if (course === "Other") {
                customInput.classList.remove("hidden");
            } else {
                customInput.classList.add("hidden");
                customInput.value = "";
            }
        }

        function forceNumeric(input) {
            input.value = input.value.replace(/[^0-9]/g, "");
        }

        function forceDecimal(input) {
            input.value = input.value
                .replace(/[^0-9.]/g, "")
                .replace(/(\..*)\./g, "$1");
        }

        // === Counselor Recommendation Viewer ===

        async function loadStudentRecommendations() {
            if (!currentStudentId || !currentTranscript) {
                alert("Select a student and load their transcript first.");
                return;
            }

            const btn = document.getElementById("viewRecsBtn");
            const panel = document.getElementById("recommendationPanel");

            btn.disabled = true;
            btn.innerText = "Loading recommendations...";

            try {
                const response = await fetch("/api/course-assigner/calculate", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        student_id: currentStudentId,
                        transcript: currentTranscript
                    })
                });

                if (!response.ok) {
                    throw new Error("Failed to load recommendations.");
                }

                const data = await response.json();
                renderRecommendationsForCounselor(data);
            } catch (err) {
                console.error(err);
                panel.classList.remove("hidden");
                panel.innerHTML = `<p class="text-red-600">Error loading recommendations.</p>`;
            } finally {
                btn.disabled = false;
                btn.innerText = "View Student Recommendations";
            }
        }

        function renderRecommendationsForCounselor(data) {
            const panel = document.getElementById("recommendationPanel");
            panel.classList.remove("hidden");

            // Try to render structured sections if keys exist
            const hs =
                data.high_school_recommendations ||
                data.highSchoolRecommendations ||
                data.recommendedHighSchoolCourses ||   // <-- your real key
                [];

            const college =
                data.college_recommendations ||
                data.collegeRecommendations ||
                data.recommendedCollegeCourses ||      // <-- your real key
                [];

            const categoryScores = data.category_scores || data.categoryScores || null;

            let html = `<h3 class="font-semibold text-emerald-900 mb-3">Recommendations</h3>`;

            if (hs.length > 0) {
                html += `
                    <div class="mb-4">
                        <h4 class="font-semibold text-sm text-emerald-800 mb-1">High School Course Recommendations</h4>
                        <ul class="space-y-1">
                            ${hs.map(r => `
                                <li class="bg-white border border-emerald-100 rounded px-3 py-2">
                                    <div class="font-medium">${typeof r === "string" ? r : (r.Name || r.CourseName || "Course")}</div>
                                </li>
                            `).join("")}
                        </ul>
                    </div>
                `;
            }

            if (college.length > 0) {
                html += `
                    <div class="mb-4">
                        <h4 class="font-semibold text-sm text-emerald-800 mb-1">College / Program Recommendations</h4>
                        <ul class="space-y-1">
                            ${college.map(r => `
                                <li class="bg-white border border-emerald-100 rounded px-3 py-2">
                                    <div class="font-medium">
                                        ${typeof r === "string"
                                    ? r
                                    : (r.Name || r.CollegeName || r.CourseName || "Program")}
                                    </div>
                                    ${r.Reason ? `<div class="text-xs text-gray-600 mt-1">${r.Reason}</div>` : ""}
                                </li>
                            `).join("")}
                        </ul>
                    </div>
                `;
            }


            if (categoryScores) {
                html += `
                    <div class="mb-4">
                        <h4 class="font-semibold text-sm text-emerald-800 mb-1">Category Strengths</h4>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                            ${Object.keys(categoryScores).map(key => `
                                <div class="bg-white border border-emerald-100 rounded px-3 py-2 flex justify-between text-xs">
                                    <span class="font-medium">${key}</span>
                                    <span>${categoryScores[key]}</span>
                                </div>
                            `).join("")}
                        </div>
                    </div>
                `;
            }

            // Fallback: show raw JSON if nothing structured was detected
            if (!hs.length && !college.length && !categoryScores) {
                html += `
                    <p class="text-xs text-gray-600 mb-2">Raw recommendation data:</p>
                    <pre class="bg-white border border-emerald-100 rounded p-3 overflow-x-auto text-xs">${escapeHtml(
                    JSON.stringify(data, null, 2)
                )}</pre>
                `;
            }

            panel.innerHTML = html;
        }

        function escapeHtml(str) {
            return String(str)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;");
        }
    </script>

</body>

</html>