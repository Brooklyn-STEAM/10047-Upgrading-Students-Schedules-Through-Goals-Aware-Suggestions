<!doctype html>
<html>

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <title>CourseTrack - Login</title>
  <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
  <link href="/static/styles.css" rel="stylesheet">
</head>

<body class="min-h-screen bg-gradient-to-br from-emerald-100 to-emerald-200 flex items-center justify-center">




  <div class="w-full max-w-md p-10 bg-white shadow-xl rounded-2xl">
    <ul class=" bg-green-100 text-green-800
 rounded-lg shadow text-center space-y-2">
    {% with messages = get_flashed_messages(with_categories=true) %}
      {% if messages %}
        <div class="space-y-3 mb-4">

          {% for category, message in messages %}

            <div class="px-4 py-3 rounded-xl text-sm font-medium border shadow-sm

              {% if category == 'danger' %}
                bg-red-100 text-red-700 border-red-200

              {% elif category == 'success' %}
                bg-emerald-100 text-emerald-700 border-emerald-200

              {% elif category == 'warning' %}
                bg-yellow-100 text-yellow-700 border-yellow-200

              {% else %}
                bg-blue-100 text-blue-700 border-blue-200
              {% endif %}
            ">
              {{ message }}
            </div>

          {% endfor %}

        </div>
      {% endif %}
    {% endwith %}
    </ul>




    <h2 class="text-3xl font-bold text-emerald-800 mb-8 text-center">
      Welcome Back
    </h2>


    <form method="post" class="space-y-5">


      <input type="email" name="email" placeholder="Email" required class="w-full px-4 py-3 border border-emerald-200 rounded-lg
                   focus:outline-none focus:ring-2 focus:ring-emerald-500
                   focus:border-emerald-500 transition" />


      <input type="password" name="password" placeholder="Password" required class="w-full px-4 py-3 border border-emerald-200 rounded-lg
                   focus:outline-none focus:ring-2 focus:ring-emerald-500
                   focus:border-emerald-500 transition" />


      <button type="submit" class="w-full py-3 bg-emerald-700 text-white font-semibold
                    rounded-lg shadow-md
                    hover:bg-emerald-800 hover:shadow-lg
                    hover:-translate-y-0.5
                    transition duration-200">
        Login
      </button>


    </form>


    <p class="text-center text-gray-500 text-sm mt-6">
      Don't have an account?
      <a href="/register" class="text-emerald-700 font-medium hover:underline">
        Register
      </a>
    </p>


  </div>


</body>


</html>