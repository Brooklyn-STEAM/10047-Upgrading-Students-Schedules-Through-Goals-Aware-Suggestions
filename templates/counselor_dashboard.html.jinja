<!doctype html>
<html class="scroll-smooth">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>CourseTrack - Counselor Dashboard</title>

  <!-- Tailwind -->
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

  <!-- Icons -->
  <script src="https://unpkg.com/feather-icons"></script>

  <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
  <link href="/static/styles.css" rel="stylesheet">
</head>


<body class="bg-gradient-to-b from-emerald-50 to-emerald-100 min-h-screen flex flex-col">

{% include "components/navbar.html.jinja" %}

<div class="w-full max-w-4xl mx-auto mt-6 mb-6 px-2 relative z-20">

  {% with messages = get_flashed_messages(with_categories=true) %}
    {% if messages %}
      <div class="space-y-3">
        {% for category, message in messages %}
          <div class="
            px-4 py-3 rounded-lg text-sm font-medium shadow
            {% if category == 'success' %}
              bg-emerald-100 text-emerald-800 border border-emerald-300
            {% elif category == 'danger' %}
              bg-red-100 text-red-800 border border-red-300
            {% elif category == 'warning' %}
              bg-yellow-100 text-yellow-800 border border-yellow-300
            {% else %}
              bg-gray-100 text-gray-800 border border-gray-300
            {% endif %}
          ">
            {{ message }}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  {% endwith %}

</div>

<main class="flex-grow flex justify-center px-6 py-12">

<div class="w-full max-w-4xl relative">

<!-- Decorative background blob -->
<div class="absolute -top-10 -right-10 w-72 h-72 bg-emerald-200 opacity-40 rounded-full blur-3xl"></div>


<!-- Dashboard Header -->
<div class="mb-10 relative z-10">

<div class="flex items-center gap-4">

<div class="bg-emerald-100 p-3 rounded-full">
<i data-feather="users" class="text-emerald-700"></i>
</div>

<div>
<h1 class="text-3xl font-bold text-emerald-900">
Welcome back, {{ current_user.name }} 

</a>
</h1>


<p class="text-emerald-700 mt-1">
View your students requests for applications:
</p>
</div>

</div>

</div>

<!-- Request Limit Control -->
<div class="mb-6 relative z-10">

  <div class="bg-white border border-emerald-200 rounded-xl p-5 shadow-sm flex flex-col md:flex-row md:items-center md:justify-between gap-4">

    <!-- Left Info -->
    <div>
      <p class="text-sm text-gray-500">Request Limit</p>
      <p class="text-lg font-semibold text-emerald-800">
        Set how many student requests you are able to accept
      </p>
      <p class="text-lg font-semibold text-emerald-800">
      Current limit: {{ request_limit if request_limit else "Unlimited" }}
      </p>
    </div>

    <!-- Form -->
    <form method="POST" action="/counselor/set_request_limit" class="flex items-center gap-3">

      <input 
        type="number" 
        name="limit" 
        min="1" 
        placeholder="e.g. 10"
        class="w-24 px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-400 focus:outline-none"
        required
      >

      <button 
        type="submit"
        class="px-4 py-2 bg-emerald-600 text-white text-sm font-semibold rounded-lg hover:bg-emerald-700 transition">
        Save
      </button>

    </form>

  </div>

</div>

<!-- Student List -->
{% if user %}

<div class="bg-white rounded-xl shadow-xl p-6 border border-emerald-100 relative z-10">

<div class="space-y-4">

{% for x in user %}
{% if x["Role"] == "student" %}

<!-- Card (now a div instead of anchor) -->
<a href="/counselor/dashboard/{{ x['student_profile_id'] }}">
  <div class="flex justify-between items-center p-5 my-2
    rounded-xl border border-emerald-200
    hover:bg-emerald-50
    hover:shadow-lg
    hover:-translate-y-1
    transition-all duration-200">
  
    <!-- Student Info -->
    <div class="flex items-center gap-4">
  
      <div class="w-10 h-10 bg-emerald-100 rounded-full flex items-center justify-center">
        <i data-feather="user" class="text-emerald-700 w-5"></i>
      </div>
  
      <!-- Clickable name -->
      <div
         class="text-lg font-medium text-gray-800">
        {{ x["Name"] }}
  
      </div>
  
    </div>
  
    <!-- Action Buttons -->
    <div class="flex items-center gap-3">
  
      {% if x['Status'] == 'Pending' %}
  
        <!-- Accept -->
        <a href="/counselor/dashboard/accept/{{ x['UserID'] }}"
          class="px-4 py-2 bg-emerald-600 text-white text-sm font-semibold rounded-lg
                  hover:bg-emerald-700 transition">
          Accept
        </a>
  
        <!-- Decline -->
        <a href="/counselor/dashboard/decline/{{ x['UserID'] }}"
          class="px-4 py-2 border border-red-500 text-red-500 text-sm font-semibold rounded-lg
                  hover:bg-red-50 transition">
          Decline
        </a>
  
      {% elif x['Status'] == 'accepted' %}
  
        <!-- VIEW (arrow button) -->
        
          <div
            class="flex items-center justify-center w-10 h-10 rounded-full bg-emerald-100 hover:bg-emerald-200 transition">
            <svg xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 text-emerald-700"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M9 5l7 7-7 7" />
            </svg>
          </div>
  
        
  
      {% endif %}
  
    </div>
  
  </div>
</a>

{% endif %}
{% endfor %}

</div>

</div>



{% else %}

<!-- Empty State -->

<div class="bg-white rounded-xl shadow-xl p-10 border border-emerald-100 text-center relative z-10">

<div class="flex justify-center mb-4">

<div class="bg-emerald-100 p-4 rounded-full">
<i data-feather="search" class="text-emerald-600 w-8 h-8"></i>
</div>

</div>

<p class="text-gray-700 text-lg font-semibold">
No students found
</p>

<p class="text-gray-500 text-sm mt-2 max-w-md mx-auto">
Assigned students will appear here once they have selected you as their counselor.
</p>

</div>

{% endif %}

</div>

</main>


{% include "components/footer.html.jinja" %}


<script>
feather.replace()
</script>

</body>
</html>