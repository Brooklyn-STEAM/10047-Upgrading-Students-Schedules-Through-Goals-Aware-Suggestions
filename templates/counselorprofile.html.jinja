<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
  <title>CourseTrack - Counselor Profile</title>
  <link href="/static/styles.css" rel="stylesheet">
</head>

<body class="bg-gradient-to-b from-emerald-50 to-emerald-100 min-h-screen flex flex-col">

{% include "components/navbar.html.jinja" %}

<main class="flex-grow flex justify-center px-6 py-12">

  <div class="w-full max-w-5xl">

    <!-- HEADER -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-emerald-900">Counselor Profile</h1>
      <p class="text-emerald-700 text-sm mt-1">Professional information and contact details</p>
    </div>

    {% set profile_pic = url_for('static', filename='profile_pics/' ~ profile.ProfilePicture) if profile and profile.ProfilePicture else url_for('static', filename='default_profile.png') %}

    <!-- MAIN CARD -->
    <div class="bg-white rounded-2xl shadow-xl border border-emerald-100 overflow-hidden">

      <!-- TOP BANNER -->
      <div class="bg-gradient-to-r from-emerald-200 to-emerald-100 p-8 flex flex-col md:flex-row items-center justify-between">

        <div class="flex items-center gap-6">
          <img 
            src="{{ profile_pic }}"
            class="w-32 h-32 rounded-full border-4 border-white shadow-lg object-cover"
          />

          <div>
            <h2 class="text-2xl font-bold text-emerald-900">
              {{ profile.Name }}
            </h2>
            <p class="text-emerald-700 text-sm mt-1">Academic Counselor</p>
          </div>
        </div>
{% if counselor_id %}
  <a href="{{ url_for('chat', user_id=counselor_id) }}"
       class="mt-3 inline-block px-4 py-2 bg-emerald-500 text-white text-sm rounded-lg hover:bg-emerald-600">
      Message Counselor
  </a>
{%else %}
    <button class="mt-3 inline-block px-4 py-2 bg-gray-400 text-white text-sm rounded-lg cursor-not-allowed" disabled>
        Message Counselor
    </button>

{% endif %}

        <!-- quick badge -->

      </div>

      <!-- CONTENT GRID -->
      <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-6">

        <div class="bg-emerald-50 p-5 rounded-xl border border-emerald-100">
          <p class="text-sm text-emerald-700">Email</p>
          <p class="text-lg font-semibold text-emerald-900">{{ profile.Email }}</p>
        </div>

        <div class="bg-emerald-50 p-5 rounded-xl border border-emerald-100">
          <p class="text-sm text-emerald-700">Phone</p>
          <p class="text-lg font-semibold text-emerald-900">
            {{ profile.Phone if profile else 'N/A' }}
          </p>
        </div>

        <div class="bg-emerald-50 p-5 rounded-xl border border-emerald-100">
          <p class="text-sm text-emerald-700">Office</p>
          <p class="text-lg font-semibold text-emerald-900">
            {{ profile.Office if profile else 'N/A' }}
          </p>
        </div>

        <div class="bg-emerald-50 p-5 rounded-xl border border-emerald-100">
          <p class="text-sm text-emerald-700">Employee ID</p>
          <p class="text-lg font-semibold text-emerald-900">N/A</p>
        </div>

      </div>

      <!-- FULL WIDTH SECTIONS -->
      <div class="px-8 pb-8 space-y-6">

        <!-- OFFICE HOURS -->
        <div>
          <h3 class="text-lg font-semibold text-emerald-800 mb-2">Office Hours</h3>
          <div class="bg-emerald-50 p-5 rounded-xl border border-emerald-100 text-gray-700">
            {{ profile.OfficeHours if profile else 'N/A' }}
          </div>
        </div>

        <!-- BIO -->
        <div>
          <h3 class="text-lg font-semibold text-emerald-800 mb-2">Professional Bio</h3>
          <div class="bg-emerald-50 p-5 rounded-xl border border-emerald-100 text-gray-700 leading-relaxed">
            {{ profile.Bio if profile else 'N/A' }}
          </div>
        </div>

      </div>

    </div>
  </div>

</main>

{% include "components/footer.html.jinja" %}

</body>
</html>