<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
  <title>CourseTrack - Student Profile</title>
  <link href="/static/styles.css" rel="stylesheet">
</head>
<body class="bg-gradient-to-b from-emerald-50 to-emerald-100 min-h-screen flex flex-col">

  {% include "components/navbar.html.jinja" %}

  <main class="flex-grow flex justify-center px-6 py-12">
  
    <div class="w-full max-w-4xl">

      <!-- Page Header -->
      <div class="mb-8 text-center md:text-left">
        <h1 class="text-3xl font-extrabold text-emerald-900 tracking-tight">Student Profile</h1>
        <p class="text-emerald-700 mt-2 text-sm md:text-base">Overview of personal information and counselor notes</p>
      </div>

      <!-- STUDENT PROFILE CARD -->
      <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-emerald-100">

        <!-- Top Section with gradient -->
        <div class="bg-gradient-to-r from-emerald-200 to-emerald-100 p-6 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
          <div class="flex items-center gap-6">
<img src="{{ url_for('static', filename='profile_pics/' ~ student.ProfilePicture) if student.ProfilePicture else url_for('static', filename='default_profile.png') }}"

              alt="Student Photo" 
              class="w-28 h-28 rounded-full border-4 border-emerald-300 shadow-lg ring-2 ring-emerald-400"
            >
            <div>
              <h2 class="text-2xl font-bold text-emerald-900">{{ student.Name }}</h2>
              <p class="text-emerald-800 mt-1 text-sm md:text-base">
                Grade: {{ student.Grade or 'N/A' }}th
              </p>
          <a href="{{ url_for('chat', user_id=student.user_id) }}"
            class="mt-3 inline-block px-4 py-2 bg-emerald-500 text-white text-sm rounded-lg hover:bg-emerald-600">
         Message Student
          </a>
            </div>
          </div>
        </div>

        <!-- Info Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 p-6">
          <div class="p-4 bg-emerald-50 rounded-xl shadow hover:shadow-md transition">
            <p class="text-sm text-emerald-700 font-medium">Student ID</p>
            <p class="text-lg font-semibold text-emerald-900">{{ student.user_id }}</p>
          </div>

          <div class="p-4 bg-emerald-50 rounded-xl shadow hover:shadow-md transition">
            <p class="text-sm text-emerald-700 font-medium">Email</p>
            <p class="text-lg font-semibold text-emerald-900">{{ student.Email }}</p>
          </div>

          <div class="p-4 bg-emerald-50 rounded-xl shadow hover:shadow-md transition">
            <p class="text-sm text-emerald-700 font-medium">Phone</p>
            <p class="text-lg font-semibold text-emerald-900">{{ student.Phone or 'N/A' }}</p>
          </div>

          <div class="p-4 bg-emerald-50 rounded-xl shadow hover:shadow-md transition">
            <p class="text-sm text-emerald-700 font-medium">Address</p>
            <p class="text-lg font-semibold text-emerald-900">{{ student.Address or 'N/A' }}</p>
          </div>
        </div>

        <!-- About Section -->
        <div class="mt-6 p-6 bg-emerald-100 rounded-l-3xl border-l-4 border-emerald-300 text-gray-700">
          <h3 class="text-xl font-semibold text-emerald-800 mb-2">About</h3>
          <p>{{ student.Bio or 'No bio provided.' }}</p>
        </div>

        <!-- Counselor Notes -->
        <div class="mt-6 p-6">
          <h3 class="text-xl font-semibold text-emerald-800 mb-3">Counselor Notes</h3>
          <form action="/counselor/dashboard/{{ student.student_profile_id }}/notes" method="POST" class="flex flex-col gap-3">
            <textarea 
              name="notes" 
              id="notes" 
              rows="5" 
              class="w-full border border-emerald-300 rounded-lg p-3 focus:ring-emerald-400 focus:border-emerald-400 shadow-sm"
              placeholder="Add your private notes here...">{{ student.CounselorNotes }}</textarea>
            <button type="submit" class="self-start text-emerald-700 ring-1 ring-emerald-400 px-5 py-2 rounded-lg font-semibold hover:bg-emerald-50 transition">
              Save Notes
            </button>
          </form>
        </div>

      </div>

    </div>
  
  </main>

  {% include "components/footer.html.jinja" %}

</body>
</html>