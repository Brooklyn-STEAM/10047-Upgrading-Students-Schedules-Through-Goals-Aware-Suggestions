<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
    <title>CourseTrack - Review Recommendations</title>
    <link href="/static/styles.css" rel="stylesheet">
  </head>
  <body class="bg-gradient-to-br from-emerald-100 via-white to-emerald-100 min-h-screen flex flex-col">
    
    {% include "components/navbar.html.jinja" %}
    
    <main class="container mx-auto my-12 px-4 flex-grow">
      
      <!-- Page Title -->
      <div class="text-center mb-10">
        <h1 class="text-4xl font-extrabold text-emerald-700 mb-2">Review Recommendations</h1>
        <p class="text-gray-500">See what others have suggested for your academic path</p>
      </div>
    
    {% if information and information|length > 0 %}
    
    {%for x in information%}
      <!-- Recommendation Card -->
      <div class="max-w-3xl mx-auto bg-white/80 backdrop-blur shadow-xl rounded-2xl p-8 border border-emerald-100 mb-8 hover:shadow-2xl transition">
        

        <!-- Header: Sent From -->
        <div class="flex items-center justify-between mb-6 border-b pb-4">
          <div>
            <p class="text-sm text-gray-400">Sent From</p>
            <h2 class="text-lg font-semibold text-gray-800">{{x['Name']}}</h2>
          </div>
          <span class="text-xs bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full font-medium">
            Counselor
          </span>
        </div>

        <!-- Recommended Courses -->
        


        <div class="mb-6">
          <h3 class="text-lg font-semibold text-emerald-700 mb-2">📚 Recommended Courses / Major</h3>
          <div class="flex flex-wrap gap-2">
            <span class="bg-emerald-50 text-emerald-700 px-3 py-1 rounded-full text-sm">{{x['Major']}}</span>
          </div>
        </div>

        <!-- Notes -->
        <div class="mb-6">
          <h3 class="text-lg font-semibold text-emerald-700 mb-2">📝 Additional Notes</h3>
          <p class="text-gray-600 leading-relaxed">
            {{x['Comments']}}
          </p>
        </div>

        <!-- Footer -->
        <div class="flex items-center justify-between border-t pt-4">
          <p class="text-sm text-gray-400">Sent on {{x['Date']}}</p>
        </div>
      </div>

      {%endfor%}
    

      <!-- Add Recommendation Button -->
      <div class="flex justify-center mt-10">
        <a href="/student/recommendation/addcounselor" 
           class="px-8 py-3 text-white bg-emerald-500 rounded-full shadow-lg hover:bg-emerald-600 hover:scale-105 transition transform">
          + Add Recommendation
        </a>
      </div>
      {% else %}

    <!-- Empty State UI -->
    <div class="max-w-2xl mx-auto text-center bg-white/80 backdrop-blur shadow-lg rounded-2xl p-10 border border-emerald-100">
    
    <h2 class="text-2xl font-bold text-emerald-700 mb-3">
      No Recommendations Yet
    </h2>

    <p class="text-gray-500 mb-6">
      You haven't received any recommendations yet. Once a counselor submits one, it will appear here.
    </p>

    <a href="/student/recommendation/addcounselor" 
       class="inline-block px-6 py-3 bg-emerald-500 text-white rounded-full shadow-md hover:bg-emerald-600 transition">
      + Request Recommendation
    </a>

  </div>

{% endif %}

    </main>

    {% include "components/footer.html.jinja" %}
    
  </body>
</html>