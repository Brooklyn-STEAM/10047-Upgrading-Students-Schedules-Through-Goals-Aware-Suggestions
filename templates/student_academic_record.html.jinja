                </div>

                <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 mt-4 rounded"
                    onclick="addScaleRow()">+
                    Add Scale Row</button>
                <button class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 mt-4 ml-2 rounded"
                    onclick="startTranscript()">Continue</button>
            </div>


            <!-- CURRICULUM SELECTOR -->
            <div id="curriculumSection" class="bg-white shadow-md rounded-lg p-4 mb-4 hidden">
                <h2 class="text-xl font-semibold mb-2">Select Your Curriculum</h2>
                <select id="curriculumSelect" class="w-full border border-gray-300 rounded-md p-2"
                    onchange="onCurriculumChange(this)">
                    <option value="USA">USA (Common Core / AP)</option>
                    <option value="IB">International Baccalaureate (IB)</option>
                    <option value="UK">UK (GCSE / A‑Level)</option>
                    <option value="CAMBRIDGE">Cambridge IGCSE / A‑Level</option>
                    <option value="CBSE">CBSE (India)</option>
                    <option value="ICSE">ICSE (India)</option>
                    <option value="BANGLADESH">Bangladesh (SSC / HSC)</option>
                    <option value="CANADA">Canada (Provincial)</option>
                    <option value="AUSTRALIA">Australia (HSC / VCE)</option>
                    <option value="OTHER">Other / International</option>
                </select>
            </div>


            <!-- STEP 4: Saving transcipt -->
            <div id="transcriptSection" class="hidden relative">
                <div class="flex justify-end mb-2">
                    <button id="addGradeBtn" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded hidden"
                        onclick="addNextGrade()">Add Grade</button>
                </div>
                <div id="transcriptContainer" class="space-y-4"></div>
                <button class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 mt-4 rounded"
                    onclick="saveChanges()">Save</button>
            </div>



            <div id="recommendationPanel" class="mt-6 hidden">

                <!-- Empty State -->
                <div id="emptyState" class="p-5 border border-gray-200 rounded-xl bg-gray-50 text-gray-600 shadow-sm">
                    <p class="text-sm">No recommendations yet. Save your transcript to see personalized suggestions.</p>
                </div>

                <!-- Results Panel -->
                <div id="resultsPanel" class="hidden space-y-6">

                    <!-- Header -->
                    <div class="flex items-center gap-2">
                        <h2 class="text-xl font-semibold text-gray-800">Your Academic Insights</h2>
                        <span class="px-2 py-1 text-xs bg-blue-100 text-blue-700 rounded-full">Beta</span>
                    </div>

                    <!-- Top Strengths -->
                    <div class="p-4 bg-white border border-gray-200 rounded-xl shadow-sm">
                        <h3 class="text-lg font-semibold text-gray-800">Top Strengths</h3>
                        <div id="topCategories" class="flex flex-wrap gap-2 mt-3"></div>
                    </div>

                    <!-- High School Recommendations -->
                    <div class="p-4 bg-white border border-gray-200 rounded-xl shadow-sm">
                        <h3 class="text-lg font-semibold text-gray-800">Recommended High‑School Courses</h3>
                        <ul id="hsRecs" class="mt-3 space-y-1 text-gray-700"></ul>
                    </div>

                    <!-- College Recommendations -->
                    <div class="p-4 bg-white border border-gray-200 rounded-xl shadow-sm">
                        <h3 class="text-lg font-semibold text-gray-800">Recommended College Courses</h3>
                        <ul id="collegeRecs" class="mt-3 space-y-1 text-gray-700"></ul>
                    </div>

                    <!-- Suggested Track -->
                    <div class="p-4 bg-white border border-gray-200 rounded-xl shadow-sm">
                        <h3 class="text-lg font-semibold text-gray-800">Suggested Track</h3>
                        <p id="trackRec" class="mt-2 text-gray-700 font-medium"></p>
                    </div>

                    <!-- Full Page Button -->
                    <button
                        class="w-full py-3 bg-blue-600 text-white rounded-xl font-medium hover:bg-blue-700 transition shadow-sm">
                        View Full Recommendations
                    </button>
                </div>
            </div>



        </div>
    </div>
