<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CourseTrack - Student Academic Record</title>
    <!-- Tailwind CSS CDN -->
    <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-b from-emerald-50 to-emerald-100 min-h-screen flex flex-col">

    {% include "components/navbar.html.jinja" %}

    <div class="container mx-auto my-10 px-4 max-w-6xl">

        <!-- STEP 1 -->
        <div id="step1" class="bg-white shadow-md rounded-lg p-6 mb-6">
            <h2 class="text-2xl font-bold mb-4">Select Student Type</h2>
            <select id="studentType" class="w-full border border-gray-300 rounded-md p-2 mb-4">
                <option value="">Select</option>
                <option value="hs">High School Student</option>
                <option value="grad">High School Graduate / University Student</option>
            </select>
            <button class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 rounded"
                onclick="goToStep2()">Next</button>
        </div>

        <!-- STEP 2 -->
        <div id="step2" class="bg-white shadow-md rounded-lg p-6 mb-6 hidden">
            <h2 class="text-2xl font-bold mb-4">Select Current Grade</h2>
            <select id="currentGrade" class="w-full border border-gray-300 rounded-md p-2 mb-4">
                <option value="">Select Grade</option>
                <option>9</option>
                <option>10</option>
                <option>11</option>
                <option>12</option>
            </select>
            <button class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 rounded"
                onclick="goToStep3()">Next</button>
        </div>

        <!-- STEP 3 -->
        <div id="step3" class="bg-white shadow-md rounded-lg p-6 mb-6 hidden">
            <h2 class="text-2xl font-bold mb-2">Customize Grading Scale</h2>
            <p class="mb-4 text-gray-700">You can edit the default grading scale below.</p>

            <div class="overflow-x-auto">
                <table id="scaleTable" class="min-w-full border border-gray-200">
                    <thead class="bg-gray-200">
                        <tr>
                            <th class="px-4 py-2 text-left">Minimum %</th>
                            <th class="px-4 py-2 text-left">Letter Grade</th>
                            <th class="px-4 py-2 text-left">Remove</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="border px-4 py-2"><input value="97"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><input value="A+"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><button onclick="removeScale(this)"
                                    class="bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded">X</button></td>
                        </tr>
                        <tr>
                            <td class="border px-4 py-2"><input value="93"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><input value="A"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><button onclick="removeScale(this)"
                                    class="bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded">X</button></td>
                        </tr>
                        <tr>
                            <td class="border px-4 py-2"><input value="90"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><input value="A-"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><button onclick="removeScale(this)"
                                    class="bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded">X</button></td>
                        </tr>
                        <tr>
                            <td class="border px-4 py-2"><input value="87"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><input value="B+"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><button onclick="removeScale(this)"
                                    class="bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded">X</button></td>
                        </tr>
                        <tr>
                            <td class="border px-4 py-2"><input value="83"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><input value="B"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><button onclick="removeScale(this)"
                                    class="bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded">X</button></td>
                        </tr>
                        <tr>
                            <td class="border px-4 py-2"><input value="80"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><input value="B-"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><button onclick="removeScale(this)"
                                    class="bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded">X</button></td>
                        </tr>
                        <tr>
                            <td class="border px-4 py-2"><input value="70"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><input value="C"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><button onclick="removeScale(this)"
                                    class="bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded">X</button></td>
                        </tr>
                        <tr>
                            <td class="border px-4 py-2"><input value="60"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><input value="D"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><button onclick="removeScale(this)"
                                    class="bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded">X</button></td>
                        </tr>
                        <tr>
                            <td class="border px-4 py-2"><input value="0"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><input value="F"
                                    class="w-full border border-gray-300 rounded p-1"></td>
                            <td class="border px-4 py-2"><button onclick="removeScale(this)"
                                    class="bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded">X</button></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 mt-4 rounded" onclick="addScaleRow()">+
                Add Scale Row</button>
            <button class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 mt-4 ml-2 rounded"
                onclick="startTranscript()">Continue</button>
        </div>

        <!-- STEP 4 -->
        <div id="transcriptSection" class="hidden relative">
            <div class="flex justify-end mb-2">
                <button id="addGradeBtn" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded hidden"
                    onclick="addNextGrade()">Add Grade</button>
            </div>
            <div id="transcriptContainer" class="space-y-4"></div>
            <button class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 mt-4 rounded"
                onclick="saveChanges()">Save</button>
        </div>

    </div>

    <script>

        const savedTranscript = {{ transcript_json| safe}};

        let gradingScale = [];
        let gradesShown = []; // Track which grades are visible
        let transcriptLoaded = false; //flag to detect whether transcript is loaded.

        const courseOptions = {
            "Math": [
                "General Math", "Mathematics", "Integrated Math", "Integrated Math I", "Integrated Math II", "Integrated Math III",
                "Algebra I", "Algebra II", "Linear Algebra",
                "Geometry", "Advanced Geometry",
                "Trigonometry", "Pre-Calculus", "Functions & Relations",
                "Calculus", "AP Calculus AB", "AP Calculus BC",
                "Statistics", "AP Statistics", "Data Analysis",
                "Higher Maths", "Further Maths", "Additional Mathematics", "Pure Mathematics", "Applied Mathematics",
                "Mathematical Methods", "Specialist Mathematics",
                "Cambridge IGCSE Mathematics", "Cambridge Additional Mathematics",
                "CBSE Mathematics", "ICSE Mathematics",
                "Other"
            ],
            "Science": [
                "General Science", "Integrated Science", "Physical Science", "Life Science",
                "Biology", "Advanced Biology", "AP Biology", "IB Biology SL", "IB Biology HL",
                "Chemistry", "Advanced Chemistry", "AP Chemistry", "IB Chemistry SL", "IB Chemistry HL",
                "Physics", "Advanced Physics", "AP Physics 1", "AP Physics 2",
                "AP Physics C: Mechanics", "AP Physics C: Electricity & Magnetism",
                "IB Physics SL", "IB Physics HL",
                "Environmental Science", "AP Environmental Science", "Earth Science", "Marine Science",
                "Home Science", "Food Science", "Health Science", "Agricultural Science",
                "Cambridge IGCSE Biology", "Cambridge IGCSE Chemistry", "Cambridge IGCSE Physics",
                "CBSE Science", "ICSE Science",
                "Other"
            ],
            "English / Language Arts": [
                "English", "English Language Arts (ELA)", "English Literature", "English Composition",
                "English 1st Paper", "English 2nd Paper",
                "English 9", "English 10", "English 11", "English 12",
                "AP English Language", "AP English Literature",
                "IB English A: Language & Literature SL", "IB English A: Language & Literature HL",
                "IB English A: Literature SL", "IB English A: Literature HL",
                "Cambridge IGCSE English", "Cambridge IGCSE Literature",
                "CBSE English", "ICSE English",
                "Other"
            ],
            "Social Studies / Humanities": [
                "History", "World History", "US History", "European History",
                "AP World History", "AP US History", "AP European History",
                "Geography", "Civics", "Government", "Political Science",
                "Sociology", "Psychology",
                "Economics", "AP Microeconomics", "AP Macroeconomics",
                "IB History SL", "IB History HL", "IB Economics SL", "IB Economics HL",
                "Cambridge IGCSE History", "Cambridge IGCSE Geography",
                "CBSE Social Science", "ICSE History & Civics",
                "Other"
            ],
            "Computer Science / Technology": [
                "Computer Science", "Information Technology", "Programming",
                "Web Development", "Software Development",
                "AP Computer Science A", "AP Computer Science Principles",
                "IB Computer Science SL", "IB Computer Science HL",
                "Data Science", "Robotics", "Artificial Intelligence",
                "Digital Literacy",
                "Cambridge IGCSE Computer Science",
                "CBSE Computer Applications", "ICSE Computer Studies",
                "Other"
            ],
            "Business / Commerce": [
                "Business Studies", "Accounting", "Finance", "Marketing", "Entrepreneurship",
                "Economics", "AP Microeconomics", "AP Macroeconomics",
                "IB Business Management SL", "IB Business Management HL",
                "Cambridge IGCSE Business Studies", "Cambridge IGCSE Accounting",
                "CBSE Business Studies", "ICSE Commercial Studies",
                "Other"
            ],
            "Arts": [
                "Visual Arts", "Fine Arts", "Music", "Drama", "Theatre",
                "Photography", "Graphic Design", "Digital Media",
                "AP Art & Design",
                "IB Visual Arts SL", "IB Visual Arts HL",
                "Cambridge IGCSE Art & Design",
                "Other"
            ],
            "Foreign Language": [
                "Spanish", "French", "German", "Mandarin", "Arabic",
                "Hindi", "Bengali", "Urdu", "Japanese", "Korean",
                "Latin", "Greek",
                "AP Spanish", "AP French",
                "IB Language B SL", "IB Language B HL",
                "Cambridge IGCSE Languages",
                "Other"
            ],
            "Physical Education / Health": [
                "Physical Education", "Health", "Sports Science", "Fitness", "Yoga",
                "IB Sports, Exercise & Health Science",
                "Cambridge IGCSE Physical Education",
                "Other"
            ],
            "Other": [
                "Other"
            ]
        };

        const mainCategories = Object.keys(courseOptions);



        // STEP NAVIGATION
        function goToStep2() {
            if (!studentType.value) { alert("Select student type"); return; }
            step1.classList.add("hidden");

            if (studentType.value === "hs") {
                step2.classList.remove("hidden");
            } else {
                step3.classList.remove("hidden");
            }
        }

        function goToStep3() {
            if (studentType.value === "hs" && !currentGrade.value) {
                alert("Select current grade");
                return;
            }
            step2.classList.add("hidden");
            step3.classList.remove("hidden");
        }

        function startTranscript() {
            gradingScale = [];

            // Read all rows from the scale table
            document.querySelectorAll("#scaleTable tbody tr").forEach(row => {
                const min = parseFloat(row.children[0].querySelector("input").value);
                const letter = row.children[1].querySelector("input").value.trim();

                if (!isNaN(min) && letter !== "") {
                    gradingScale.push({ letter, min });
                }
            });

            // Sort highest → lowest
            gradingScale.sort((a, b) => b.min - a.min);

            // Hide Step 3
            document.getElementById("step3").classList.add("hidden");

            // Show transcript section (Step 4)
            document.getElementById("transcriptSection").classList.remove("hidden");

            // Build transcript UI
            buildTranscript();
        }



        function buildScale() {
            gradingScale = [];
            const rows = document.querySelectorAll("#scaleTable tbody tr");
            rows.forEach(row => {
                const min = parseFloat(row.children[0].children[0].value);
                const letter = row.children[1].children[0].value;
                if (!isNaN(min) && letter) {
                    gradingScale.push({ min, letter });
                }
            });
            gradingScale.sort((a, b) => b.min - a.min);
        }

        function calculateLetter(mark) {
            for (let rule of gradingScale) {
                if (mark >= rule.min) return rule.letter;
            }
            return "";
        }

        function convertToLetter(marks) {
            // gradingScale must be sorted from highest min → lowest min
            for (const grade of gradingScale) {
                if (marks >= grade.min) {
                    return grade.letter;
                }
            }
            return ""; // fallback (should never happen)
        }



        function addScaleRow() {
            const row = document.createElement("tr");
            row.innerHTML = `
    <td class="border px-4 py-2"><input class="w-full border border-gray-300 rounded p-1"></td>
    <td class="border px-4 py-2"><input class="w-full border border-gray-300 rounded p-1"></td>
    <td class="border px-4 py-2"><button onclick="removeScale(this)"
            class="bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded">X</button></td>
    `;
            document.querySelector("#scaleTable tbody").appendChild(row);
        }

        function removeScale(btn) {
            btn.parentElement.parentElement.remove();
        }

        // BUILD TRANSCRIPT
        function buildTranscript() {
            gradesShown = [];
            const maxGrade = studentType.value === "grad" ? 12 : parseInt(currentGrade.value);
            for (let g = 9; g <= maxGrade; g++) { gradesShown.push(g); } rebuildTranscript();
        } function addGradeSection(g) {
            const container = document.getElementById("transcriptContainer"); container.innerHTML += ` <div
        id="gradeSection${g}">
        <div class="grade-header flex justify-between items-center bg-green-600 text-white px-4 py-2 font-bold cursor-pointer"
            onclick="toggleGrade(${g})">

            <span>Grade ${g}</span>
            <div class="flex items-center space-x-2">
                <button class="bg-red-600 hover:bg-red-700 px-2 py-1 rounded text-sm"
                    onclick="event.stopPropagation(); removeGrade(${g})">
                    Remove
                </button>

                <span id="arrow${g}">▼</span>

            </div>
        </div>
        <div class="grade-content hidden bg-white shadow-md rounded p-4 mt-2" id="content${g}">
            <div class="overflow-x-auto">
                <table class="min-w-full border border-gray-200">
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th>Subject</th>
                            <th>Marks</th>
                            <th>Letter</th>
                            <th>Credits</th>
                            <th>Preference</th>
                            <th>Remove</th>
                        </tr>
                    </thead>

                    <tbody id="tableBody${g}"></tbody>
                </table>
            </div>
            <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 mt-2 rounded" onclick="addRow(${g})">+ Add
                Subject</button>
            <div class="gpa-display mt-2 font-bold">GPA: <span id="gpa${g}">0.00</span></div>
        </div>
        </div>
        `;
        }

        // REBUILD TRANSCRIPT IN ORDER
        function rebuildTranscript() {
            const container = document.getElementById("transcriptContainer");
            container.innerHTML = "";
            gradesShown.sort((a, b) => a - b); // ascending
            gradesShown.forEach(g => addGradeSection(g));
            updateAddGradeButton();
        }

        function updateAddGradeButton() {
            const btn = document.getElementById("addGradeBtn");
            const missing = [9, 10, 11, 12].some(g => !gradesShown.includes(g));
            btn.style.display = missing ? "inline-block" : "none";
        }
        function generateGradeSectionHTML(g) {
            return `
        <div id="gradeSection${g}">
            <div class="grade-header flex justify-between items-center bg-green-600 text-white px-4 py-2 font-bold cursor-pointer"
                onclick="toggleGrade(${g})">

                <span>Grade ${g}</span>
                <div class="flex items-center space-x-2">
                    <button class="bg-red-600 hover:bg-red-700 px-2 py-1 rounded text-sm"
                        onclick="event.stopPropagation(); removeGrade(${g})">
                        Remove
                    </button>

                    <span id="arrow${g}">▼</span>
                </div>
            </div>

            <div class="grade-content hidden bg-white shadow-md rounded p-4 mt-2" id="content${g}">
                <div class="overflow-x-auto">
                    <table class="min-w-full border border-gray-200">
                        <thead class="bg-gray-200">
                            <tr>
                                <th class="px-4 py-2 text-left">Subject</th>
                                <th class="px-4 py-2 text-left">Marks (%)</th>
                                <th class="px-4 py-2 text-left">Letter</th>
                                <th class="px-4 py-2 text-left">Credits</th>
                                <th class="px-4 py-2 text-left">Preference (1–5)</th>
                                <th class="px-4 py-2 text-left">Remove</th>
                            </tr>
                        </thead>
                        <tbody id="tableBody${g}"></tbody>
                    </table>
                </div>

                <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 mt-2 rounded"
                    onclick="addRow(${g})">+ Add Subject</button>

                <div class="gpa-display mt-2 font-bold">GPA: <span id="gpa${g}">0.00</span></div>
            </div>
        </div>
    `;
        }

        function insertGradeSectionInOrder(g) {
            const container = document.getElementById("transcriptContainer");
            const newSection = document.createElement("div");
            newSection.id = `gradeSection${g}`;
            newSection.innerHTML = generateGradeSectionHTML(g); // we’ll reuse your existing HTML builder

            // Find the correct place to insert
            const existingSections = Array.from(container.children);

            for (let section of existingSections) {
                const sectionGrade = parseInt(section.id.replace("gradeSection", ""));
                if (g < sectionGrade) {
                    container.insertBefore(newSection, section);
                    return;
                }
            }

            // If no earlier grade found → append at end
            container.appendChild(newSection);
        }

        function addNextGrade() {
            if (transcriptLoaded) {
                // Do NOT reset transcript
                for (let g = 9; g <= 12; g++) {
                    if (!gradesShown.includes(g)) {
                        gradesShown.push(g);
                        insertGradeSectionInOrder(g);
                        break;
                    }
                }
                return;
            }

            // Normal behavior for first-time users
            for (let g = 9; g <= 12; g++) {
                if (!gradesShown.includes(g)) {
                    gradesShown.push(g);
                    rebuildTranscript();
                    break;
                }
            }
        }

        function removeGrade(g) {
            if (!confirm(`Are you sure you want to remove Grade ${g}? This cannot be undone.`)) {
                return;
            }

            // Remove from list
            gradesShown = gradesShown.filter(x => x !== g);

            if (transcriptLoaded) {
                // Remove ONLY the grade section from the DOM
                const section = document.getElementById(`gradeSection${g}`);
                if (section) section.remove();

                updateAddGradeButton();
                return;
            }

            // First-time user behavior
            rebuildTranscript();
        }


        function toggleGrade(g) {
            const content = document.getElementById("content" + g);
            const arrow = document.getElementById("arrow" + g);
            content.classList.toggle("hidden");
            arrow.innerText = content.classList.contains("hidden") ? "▼" : "▲";
        }

        function addRow(g) {
            const row = document.createElement("tr");

            const categoryOptionsHtml = mainCategories
                .map(c => `<option value="${c}">${c}</option>`)
                .join("");

            row.innerHTML = `
        <!-- Category -->
        <td class="border px-4 py-2">
            <select class="w-full border border-gray-300 rounded p-1"
                    onchange="onCategoryChange(this, ${g})">
                <option value="">Select category</option>
                ${categoryOptionsHtml}
            </select>
        </td>

        <!-- Subject (Course) -->
        <td class="border px-4 py-2">
            <select class="w-full border border-gray-300 rounded p-1"
                    onchange="onCourseChange(this, ${g})">
                <option value="">Select course</option>
            </select>
            <input class="w-full border border-gray-300 rounded p-1 mt-1 hidden"
                   placeholder="Enter course name"
                   oninput="onCustomCourseInput(this, ${g})">
        </td>

        <!-- Marks -->
        <td class="border px-4 py-2">
            <input type="text"
       oninput="forceNumeric(this); updateGrade(this, ${g})"
       class="w-full border border-gray-300 rounded p-1">



        </td>

        <!-- Letter -->
        <td class="border px-4 py-2">
            <input readonly
                   class="w-full border border-gray-300 rounded p-1 bg-gray-100">
        </td>

        <!-- Credits -->
        <td class="border px-4 py-2">
            <input type="text"
       oninput="forceDecimal(this); updateGPA(${g})"
       class="w-full border border-gray-300 rounded p-1">


        </td>

        <!-- Preference -->
        <td class="border px-4 py-2">
            <select class="w-full border border-gray-300 rounded p-1">
                <option value="">--</option>
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4</option>
                <option value="5">5</option>
            </select>
        </td>

        <!-- Remove -->
        <td class="border px-4 py-2">
            <button class="bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded"
                    onclick="deleteRow(this, ${g})">X</button>
        </td>
    `;

            document.getElementById("tableBody" + g).appendChild(row);
        }


        function forceNumeric(input) {
            input.value = input.value.replace(/[^0-9]/g, "");
        }

        function forceDecimal(input) {
            // Remove invalid characters
            input.value = input.value.replace(/[^0-9.]/g, "");

            // Prevent more than one decimal point
            const parts = input.value.split(".");
            if (parts.length > 2) {
                input.value = parts[0] + "." + parts[1];
            }
        }


        function onCategoryChange(select, g) {
            const row = select.closest("tr");
            const courseSelect = row.children[1].querySelector("select");
            const customInput = row.children[1].querySelector("input");

            const category = select.value;
            courseSelect.innerHTML = `<option value="">Select course</option>`;

            if (!category || !courseOptions[category]) {
                customInput.classList.add("hidden");
                customInput.value = "";
                return;
            }

            courseOptions[category].forEach(c => {
                const opt = document.createElement("option");
                opt.value = c;
                opt.textContent = c;
                courseSelect.appendChild(opt);
            });

            customInput.classList.add("hidden");
            customInput.value = "";
        }

        function onCourseChange(select, g) {
            const row = select.closest("tr");
            const customInput = row.children[1].querySelector("input");

            if (select.value === "Other") {
                customInput.classList.remove("hidden");
            } else {
                customInput.classList.add("hidden");
                customInput.value = "";
            }
        }

        function onCustomCourseInput(input, g) {
            // optional: extra validation later
        }


        function updateGrade(input, gradeLevel) {
            const row = input.closest("tr");
            const marks = parseFloat(input.value);

            const letterInput = row.children[3].querySelector("input");

            if (!isNaN(marks)) {
                letterInput.value = convertToLetter(marks);
            } else {
                letterInput.value = "";
            }

            // 🔥 Recalculate GPA immediately
            updateGPA(gradeLevel);
        }




        function deleteRow(btn, g) {
            btn.parentElement.parentElement.remove();
            updateGPA(g);
        }

        function letterToPoint(letter) {
            const scale = {
                "A+": 4, "A": 4, "A-": 3.7,
                "B+": 3.3, "B": 3, "B-": 2.7,
                "C+": 2.3, "C": 2, "D": 1, "F": 0
            };
            return scale[letter] || 0;
        }

        function updateGPA(g) {
            const rows = document.querySelectorAll("#tableBody" + g + " tr");
            let total = 0, credits = 0;

            rows.forEach(r => {
                const letter = r.children[3].querySelector("input").value;
                const cred = parseFloat(r.children[4].querySelector("input").value);

                if (letter && !isNaN(cred) && cred > 0) {
                    total += letterToPoint(letter) * cred;
                    credits += cred;
                }
            });

            const gpa = credits > 0 ? (total / credits).toFixed(2) : "0.00";
            document.getElementById("gpa" + g).innerText = gpa;
        }


        async function saveChanges() {
            let grades = [];

            gradesShown.forEach(g => {
                const subjects = [];

                document.querySelectorAll(`#tableBody${g} tr`).forEach(row => {
                    const categorySelect = row.querySelector("td:nth-child(1) select");
                    const courseSelect = row.querySelector("td:nth-child(2) select");
                    const customInput = row.querySelector("td:nth-child(2) input");

                    const marksInput = row.querySelector("td:nth-child(3) input");
                    const letterInput = row.querySelector("td:nth-child(4) input");
                    const creditsInput = row.querySelector("td:nth-child(5) input");
                    const prefSelect = row.querySelector("td:nth-child(6) select");

                    const mainCategory = categorySelect.value || null;
                    const courseName = courseSelect.value || null;
                    const customCourseName = customInput.classList.contains("hidden") ? null : (customInput.value.trim() || null);

                    const marks = parseFloat(marksInput.value);
                    const letter = letterInput.value;
                    const credits = parseFloat(creditsInput.value);
                    const preference = parseInt(prefSelect.value);

                    // basic validation: skip completely empty rows
                    if (!mainCategory && !courseName && isNaN(marks) && isNaN(credits) && !preference) {
                        return;
                    }

                    subjects.push({
                        MainCategory: mainCategory,
                        CourseName: courseName,
                        CustomCourseName: customCourseName,
                        Marks: isNaN(marks) ? null : marks,
                        Letter: letter || null,
                        Credits: isNaN(credits) ? null : credits,
                        Preference: isNaN(preference) ? null : preference,
                        // Name kept for backward compatibility / display
                        Name: customCourseName || courseName || ""
                    });
                });

                if (subjects.length > 0) {
                    let total = 0, creditsSum = 0;

                    subjects.forEach(sub => {
                        if (sub.Credits && sub.Letter) {
                            let point = letterToPoint(sub.Letter);
                            total += point * sub.Credits;
                            creditsSum += sub.Credits;
                        }
                    });

                    let gpa = creditsSum ? (total / creditsSum).toFixed(2) : 0;

                    grades.push({
                        GradeLevel: g,
                        GPA: gpa,
                        Subjects: subjects
                    });
                }
            });

            let total = 0, creditsSum = 0;
            grades.forEach(gr => {
                total += parseFloat(gr.GPA);
                creditsSum++;
            });
            let overallGPA = creditsSum ? (total / creditsSum).toFixed(2) : 0;

            console.log("Saving transcript:", { GPA: overallGPA, Grades: grades });

            try {
                const response = await fetch("/save_transcript", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        GPA: overallGPA,
                        Grades: grades
                    })
                });

                const data = await response.json();
                alert(data.message);

            } catch (err) {
                console.error(err);
                alert("Error saving transcript. See console.");
            }
        }



        function loadSavedTranscript(data) {
            transcriptLoaded = true;
            buildScale();

            if (!data || !data.Grades || data.Grades.length === 0) {
                step1.classList.remove("hidden");
                return;
            }

            // Skip steps 1–3
            step1.classList.add("hidden");
            step2.classList.add("hidden");
            step3.classList.add("hidden");
            transcriptSection.classList.remove("hidden");

            // Build grade sections
            gradesShown = data.Grades.map(g => g.GradeLevel);
            rebuildTranscript();

            // Fill subjects
            data.Grades.forEach(g => {
                const tbody = document.querySelector(`#tableBody${g.GradeLevel}`);

                g.Subjects.forEach(sub => {
                    const row = document.createElement("tr");
                    const categoryOptionsHtml = mainCategories.map(c => `
    <option value="${c}" ${sub.MainCategory === c ? "selected" : ""}>${c}</option>
`).join("");

                    // determine course list for this subject
                    let courseList = [];
                    if (sub.MainCategory && courseOptions[sub.MainCategory]) {
                        courseList = courseOptions[sub.MainCategory];
                    }

                    const courseOptionsHtml = ['<option value="">Select course</option>']
                        .concat(courseList.map(c => `<option value="${c}" ${sub.CourseName === c ? "selected" : ""}>${c}</option>`))
                        .join("");

                    const isOther = sub.CourseName === "Other";
                    const customName = sub.CustomCourseName || (isOther ? (sub.Name || "") : "");

                    row.innerHTML = `
    <!-- Category -->
    <td class="border px-4 py-2">
        <select class="w-full border border-gray-300 rounded p-1"
                onchange="onCategoryChange(this, ${g.GradeLevel})">
            <option value="">Select category</option>
            ${categoryOptionsHtml}
        </select>
    </td>

    <!-- Subject (Course) -->
    <td class="border px-4 py-2">
        <select class="w-full border border-gray-300 rounded p-1"
                onchange="onCourseChange(this, ${g.GradeLevel})">
            ${courseOptionsHtml}
        </select>
        <input class="w-full border border-gray-300 rounded p-1 mt-1 ${isOther ? "" : "hidden"}"
               placeholder="Enter course name"
               value="${customName}">
    </td>

    <!-- Marks -->
    <td class="border px-4 py-2">
       <input type="text"
       value="${sub.Marks ?? ''}"
       oninput="forceNumeric(this); updateGrade(this, ${g.GradeLevel})"
       class="w-full border rounded p-1">


    </td>

    <!-- Letter -->
    <td class="border px-4 py-2">
        <input value="${sub.Letter ?? ''}" readonly 
               class="w-full border rounded p-1 bg-gray-100">
    </td>

    <!-- Credits -->
    <td class="border px-4 py-2">
        <input type="text"
       value="${sub.Credits ?? ''}"
       oninput="forceDecimal(this); updateGPA(${g.GradeLevel})"
       class="w-full border rounded p-1">


    </td>

    <!-- Preference -->
    <td class="border px-4 py-2">
        <select class="w-full border border-gray-300 rounded p-1">
            <option value="">--</option>
            <option value="1" ${sub.Preference == 1 ? "selected" : ""}>1</option>
            <option value="2" ${sub.Preference == 2 ? "selected" : ""}>2</option>
            <option value="3" ${sub.Preference == 3 ? "selected" : ""}>3</option>
            <option value="4" ${sub.Preference == 4 ? "selected" : ""}>4</option>
            <option value="5" ${sub.Preference == 5 ? "selected" : ""}>5</option>
        </select>
    </td>

    <!-- Remove -->
    <td class="border px-4 py-2">
        <button onclick="deleteRow(this, ${g.GradeLevel})"
                class="bg-red-600 text-white px-2 py-1 rounded">
            X
        </button>
    </td>
`;



                    tbody.appendChild(row);
                });

                updateGPA(g.GradeLevel);
            });
        }

        if (savedTranscript) {
            loadSavedTranscript(savedTranscript);
        }

    </script>

    {% include "components/footer.html.jinja" %}


</body>

</html>