<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CourseTrack - Student Academic Record</title>
    <!-- Tailwind CSS CDN -->
    <link rel="icon" type="image/png" href="{{ url_for('static', filename='images/logo.png') }}">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .gpa-tab {
            padding: 0.5rem 0;
            border-bottom: 2px solid transparent;
        }

        .gpa-tab.active-tab {
            border-color: #2563eb;
            /* blue-600 */
            font-weight: 600;
            color: #2563eb;
        }
    </style>

</head>

<body class="bg-gradient-to-b from-emerald-50 to-emerald-100 min-h-screen flex flex-col">

    {% include "components/navbar.html.jinja" %}

    <div class="container mx-auto my-10 px-4 max-w-6xl">

        <!-- STEP 1 -->
        <div id="step1" class="bg-white shadow-md rounded-lg p-6 mb-6">
            <h2 class="text-2xl font-bold mb-4">Select Student Type</h2>
            <select id="studentType" class="w-full border border-gray-300 rounded-md p-2 mb-4">
                <option value="">Select</option>
                <option value="hs">High School Student</option>
                <option value="grad">High School Graduate / University Student</option>
            </select>
            <button class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 rounded"
                onclick="goToStep2()">Next</button>
        </div>

        <!-- STEP 2 -->
        <div id="step2" class="bg-white shadow-md rounded-lg p-6 mb-6 hidden">
            <h2 class="text-2xl font-bold mb-4">Select Current Grade</h2>
            <select id="currentGrade" class="w-full border border-gray-300 rounded-md p-2 mb-4">
                <option value="">Select Grade</option>
                <option>9</option>
                <option>10</option>
                <option>11</option>
                <option>12</option>
            </select>
            <button class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 rounded"
                onclick="goToStep3()">Next</button>
        </div>

        <!-- STEP 3 -->

        <div id="step3" class="hidden">
            <h2 class="text-2xl font-bold mb-4">GPA Settings</h2>

            <!-- Tabs -->
            <div class="border-b mb-4 flex space-x-6">
                <button class="gpa-tab active-tab" data-tab="systemTab">GPA System</button>
                <button class="gpa-tab" data-tab="scaleTab">Scale</button>
                <button class="gpa-tab" data-tab="weightingTab">Weighting</button>
                <button class="gpa-tab" data-tab="advancedTab">Advanced</button>
            </div>

            <!-- GPA SYSTEM TAB -->
            <div id="systemTab" class="gpa-tab-content">
                <label class="block font-semibold mb-2">Select GPA System</label>
                <select id="presetGPA" class="border p-2 rounded w-full mb-4">
                    <option value="us_4">US 4.0 (Unweighted)</option>
                    <option value="us_5">US 5.0 (Weighted)</option>
                    <option value="ib">IB (1–7)</option>
                    <option value="uk">UK (A*–E)</option>
                    <option value="asia_4">Asia (100 → 4.0)</option>
                    <option value="asia_5">Asia (100 → 5.0)</option>
                    <option value="custom">Custom</option>
                </select>

                <button onclick="applyPresetGPA()" class="bg-blue-600 text-white px-4 py-2 rounded">
                    Apply System
                </button>
            </div>

            <!-- SCALE TAB -->
            <div id="scaleTab" class="gpa-tab-content hidden">
                <h3 class="font-semibold mb-2">Marks → Letter Conversion</h3>
                <div id="scaleTableContainer"></div>
            </div>

            <!-- WEIGHTING TAB -->
            <div id="weightingTab" class="gpa-tab-content hidden">
                <h3 class="font-semibold mb-2">Weighting Rules</h3>
                <div id="weightingTableContainer"></div>
            </div>

            <!-- ADVANCED TAB -->
            <div id="advancedTab" class="gpa-tab-content hidden">
                <label class="block font-semibold mb-2">Max GPA</label>
                <input id="maxGPAInput" type="number" step="0.1" class="border p-2 rounded w-full">
            </div>

            <!-- Footer -->
            <div class="flex justify-end mt-6">
                <button onclick="goBackToStep2()" class="px-4 py-2 mr-2">Back</button>
                <button onclick="saveGPASettingsAndContinue()" class="bg-green-600 text-white px-4 py-2 rounded">
                    Continue to Transcript
                </button>
            </div>
        </div>



        <!-- STEP 4 -->
        <div class="flex gap-3 mb-4">
            <button onclick="openGPASettings()" class="bg-blue-600 text-white px-4 py-2 rounded">
                Change GPA System
            </button>

            <button onclick="openScaleSettings()" class="bg-blue-600 text-white px-4 py-2 rounded">
                Marks → Letter Conversion
            </button>

            <button onclick="openAdvancedGPASettings()" class="bg-gray-700 text-white px-4 py-2 rounded">
                Advanced GPA Settings
            </button>
        </div>


        <div id="transcriptSection" class="hidden relative">
            <div class="flex justify-end mb-2">
                <button id="addGradeBtn" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded hidden"
                    onclick="addNextGrade()">Add Grade</button>
            </div>
            <div id="transcriptContainer" class="space-y-4"></div>
            <button class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 mt-4 rounded"
                onclick="saveChanges()">Save</button>
        </div>

    </div>

    <script>
        let gpaSettings = null;

        const savedTranscript = {{ transcript_json| safe}};

        let gradingScale = [];
        let gradesShown = []; // Track which grades are visible
        let transcriptLoaded = false; //flag to detect whether transcript is loaded.


        document.addEventListener("click", function (e) {
            if (e.target.classList.contains("gpa-tab")) {
                const tab = e.target.dataset.tab;

                document.querySelectorAll(".gpa-tab-content").forEach(el => el.classList.add("hidden"));
                document.getElementById(tab).classList.remove("hidden");

                document.querySelectorAll(".gpa-tab").forEach(b => b.classList.remove("active-tab"));
                e.target.classList.add("active-tab");
            }
        });

        const courseOptions = {
