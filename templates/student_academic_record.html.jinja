        function letterToPoint(letter) {
            const scale = {
                "A+": 4, "A": 4, "A-": 3.7,
                "B+": 3.3, "B": 3, "B-": 2.7,
                "C+": 2.3, "C": 2, "D": 1, "F": 0
            };
            return scale[letter] || 0;
        }

        function updateGPA(g) {
            const rows = document.querySelectorAll("#tableBody" + g + " tr");
            let total = 0, credits = 0;

            rows.forEach(r => {
                const letter = r.children[3].querySelector("input").value;
                const cred = parseFloat(r.children[4].querySelector("input").value);

                if (letter && !isNaN(cred) && cred > 0) {


                    total += letterToPoint(letter) * cred;
                    credits += cred;
                }
            });

            const gpa = credits > 0 ? (total / credits).toFixed(2) : "0.00";
            document.getElementById("gpa" + g).innerText = gpa;
        }

        function showRecommendations(data) {
            const panel = document.getElementById("recommendationPanel");
            const emptyState = document.getElementById("emptyState");
            const resultsPanel = document.getElementById("resultsPanel");

            panel.classList.remove("hidden");

            if (!data.topCategories || data.topCategories.length === 0) {
                emptyState.classList.remove("hidden");
                resultsPanel.classList.add("hidden");
                return;
            }

            emptyState.classList.add("hidden");
            resultsPanel.classList.remove("hidden");

            // Top categories
            const topCatDiv = document.getElementById("topCategories");
            topCatDiv.innerHTML = "";
            data.topCategories.slice(0, 3).forEach(cat => {
                const badge = `
            <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm font-medium shadow-sm">
                ${cat}
            </span>`;
                topCatDiv.innerHTML += badge;
            });

            // High school recs
            const hsList = document.getElementById("hsRecs");
            hsList.innerHTML = "";
            data.recommendedHighSchoolCourses.slice(0, 3).forEach(c => {
                hsList.innerHTML += `
            <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                ${c}
            </li>`;
            });

            // College recs
            const colList = document.getElementById("collegeRecs");
            colList.innerHTML = "";
            data.recommendedCollegeCourses.slice(0, 3).forEach(c => {
                colList.innerHTML += `
            <li class="flex items-center gap-2">
                <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                ${c}
            </li>`;
            });

            // Track
            document.getElementById("trackRec").innerText =
                data.suggestedTracks?.[0] || "—";
        }




        async function saveChanges() {
            let grades = [];

            gradesShown.forEach(g => {
                const subjects = [];

                document.querySelectorAll(`#tableBody${g} tr`).forEach(row => {
                    const categorySelect = row.querySelector("td:nth-child(1) select");
                    const courseSelect = row.querySelector("td:nth-child(2) select");
                    const customInput = row.querySelector("td:nth-child(2) input");

                    const marksInput = row.querySelector("td:nth-child(3) input");
                    const letterInput = row.querySelector("td:nth-child(4) input");
                    const creditsInput = row.querySelector("td:nth-child(5) input");
                    const prefSelect = row.querySelector("td:nth-child(6) select");

                    const mainCategory = categorySelect.value || null;
                    const courseName = courseSelect.value || null;
                    const customCourseName = customInput.classList.contains("hidden") ? null : (customInput.value.trim() || null);

                    const marks = parseFloat(marksInput.value);
                    const letter = letterInput.value;
                    const credits = parseFloat(creditsInput.value);
                    const preference = parseInt(prefSelect.value);

                    // basic validation: skip completely empty rows
                    if (!mainCategory && !courseName && isNaN(marks) && isNaN(credits) && !preference) {
                        return;
                    }

                    subjects.push({
                        MainCategory: mainCategory,
                        CourseName: courseName,
                        CustomCourseName: customCourseName,
                        Marks: isNaN(marks) ? null : marks,
                        Letter: letter || null,
                        Credits: isNaN(credits) ? null : credits,
                        Preference: isNaN(preference) ? null : preference,
                        Name: customCourseName || courseName || ""
                    });
                });

                if (subjects.length > 0) {
                    let total = 0, creditsSum = 0;

                    subjects.forEach(sub => {
                        if (sub.Credits && sub.Letter) {
                            let point = letterToPoint(sub.Letter);
                            total += point * sub.Credits;
                            creditsSum += sub.Credits;
                        }
                    });

                    let gpa = creditsSum ? (total / creditsSum).toFixed(2) : 0;

                    grades.push({
                        GradeLevel: g,
                        GPA: gpa,
                        Subjects: subjects
                    });
                }
            });

            let total = 0, creditsSum = 0;
            grades.forEach(gr => {
                total += parseFloat(gr.GPA);
                creditsSum++;
            });
            let overallGPA = creditsSum ? (total / creditsSum).toFixed(2) : 0;

            console.log("Saving transcript:", { GPA: overallGPA, Grades: grades });

            // Build transcript object for Course Assigner
            const transcriptForAssigner = {
                Grades: grades
            };

            // Build letter scale for Course Assigner
            const letterScaleForAssigner = gradingScale.map(rule => ({
                Letter: rule.letter,
                Min: rule.min,
                Points: letterToPoint(rule.letter)
            }));


            // ============================================================
            // ⭐ CALL COURSE ASSIGNER + UPDATE PHASE 2 UI
            // ============================================================
            try {
                const assignerResponse = await fetch("/api/course-assigner/calculate", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        transcript: transcriptForAssigner,
                        letterScale: letterScaleForAssigner,
                        curriculum: selectedCurriculum
                    })

                });

                const assignerData = await assignerResponse.json();
                console.log("Course Assigner Result:", assignerData);

                // ⭐ Phase 2 UI update
                showRecommendations(assignerData);

            } catch (err) {
                console.error("Error calling Course Assigner:", err);
            }
            // ============================================================


            // ============================================================
            // SAVE TRANSCRIPT TO YOUR BACKEND
            // ============================================================
            try {
                const response = await fetch("/save_transcript", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        GPA: overallGPA,
                        Grades: grades,
                        Curriculum: selectedCurriculum
                    })
                });

                const data = await response.json();
                alert(data.message);

            } catch (err) {
                console.error(err);
                alert("Error saving transcript. See console.");
            }
        }







        function loadSavedTranscript(data) {
            transcriptLoaded = true;
            buildScale();

            if (!data || !data.Grades || data.Grades.length === 0) {
                step1.classList.remove("hidden");
                return;
            }

            // Skip steps 1–3
            step1.classList.add("hidden");
            step2.classList.add("hidden");
            step3.classList.add("hidden");
            transcriptSection.classList.remove("hidden");

            // ⭐ Always show curriculum selector
            curriculumSection.classList.remove("hidden");

            // ⭐ Restore saved curriculum BEFORE rebuilding transcript
            if (data.Curriculum) {
                selectedCurriculum = data.Curriculum;
                const cs = document.getElementById("curriculumSelect");
                cs.value = selectedCurriculum;
            }

            // ⭐ Build grade sections
            gradesShown = data.Grades.map(g => g.GradeLevel);
            rebuildTranscript();

            // ⭐ Apply curriculum filtering to all dropdowns BEFORE inserting rows
            onCurriculumChange(document.getElementById("curriculumSelect"));

            // ⭐ Fill subjects
            data.Grades.forEach(g => {
                const tbody = document.querySelector(`#tableBody${g.GradeLevel}`);

                g.Subjects.forEach(sub => {
                    const row = document.createElement("tr");

                    // Category dropdown
                    const categories = Object.keys(courseOptions[selectedCurriculum] || {});
                    const categoryOptionsHtml = categories.map(c => `
                        <option value="${c}" ${sub.MainCategory === c ? "selected" : ""}>${c}</option>
                        `).join("");


                    // ⭐ Determine course list (curriculum-aware)
                    let courseList = [];
                    if (sub.MainCategory && courseOptions[sub.MainCategory]) {
                        courseList = getCoursesForCategory(sub.MainCategory);
                    }

                    // ⭐ Ensure saved course appears even if filtered out
                    if (sub.CourseName && !courseList.includes(sub.CourseName)) {
                        courseList.unshift(sub.CourseName);
                    }

                    const courseOptionsHtml = ['<option value="">Select course</option>']
                        .concat(courseList.map(c => `
                    <option value="${c}" ${sub.CourseName === c ? "selected" : ""}>${c}</option>
                `))
                        .join("");

                    const isOther = sub.CourseName === "Other";
                    const customName = sub.CustomCourseName || (isOther ? (sub.Name || "") : "");

                    row.innerHTML = `
                <!-- Category -->
                <td class="border px-4 py-2">
                    <select class="w-full border border-gray-300 rounded p-1"
                            onchange="onCategoryChange(this, ${g.GradeLevel})">
                        <option value="">Select category</option>
                        ${categoryOptionsHtml}
                    </select>
                </td>

                <!-- Subject (Course) -->
                <td class="border px-4 py-2">
                    <select class="w-full border border-gray-300 rounded p-1"
                            onchange="onCourseChange(this, ${g.GradeLevel})">
                        ${courseOptionsHtml}
                    </select>
                    <input class="w-full border border-gray-300 rounded p-1 mt-1 ${isOther ? "" : "hidden"}"
                           placeholder="Enter course name"
                           value="${customName}">
                </td>

                <!-- Marks -->
                <td class="border px-4 py-2">
                    <input type="text"
                           value="${sub.Marks ?? ''}"
                           oninput="forceNumeric(this); updateGrade(this, ${g.GradeLevel})"
                           class="w-full border rounded p-1">
                </td>

                <!-- Letter -->
                <td class="border px-4 py-2">
                    <input value="${sub.Letter ?? ''}" readonly 
                           class="w-full border rounded p-1 bg-gray-100">
                </td>

                <!-- Credits -->
                <td class="border px-4 py-2">
                    <input type="text"
                           value="${sub.Credits ?? ''}"
                           oninput="forceDecimal(this); updateGPA(${g.GradeLevel})"
                           class="w-full border rounded p-1">
                </td>

                <!-- Preference -->
                <td class="border px-4 py-2">
                    <select class="w-full border border-gray-300 rounded p-1">
                        <option value="">--</option>
                        <option value="1" ${sub.Preference == 1 ? "selected" : ""}>1</option>
                        <option value="2" ${sub.Preference == 2 ? "selected" : ""}>2</option>
                        <option value="3" ${sub.Preference == 3 ? "selected" : ""}>3</option>
                        <option value="4" ${sub.Preference == 4 ? "selected" : ""}>4</option>
                        <option value="5" ${sub.Preference == 5 ? "selected" : ""}>5</option>
                    </select>
                </td>

                <!-- Remove -->
                <td class="border px-4 py-2">
                    <button onclick="deleteRow(this, ${g.GradeLevel})"
                            class="bg-red-600 text-white px-2 py-1 rounded">
                        X
                    </button>
                </td>
            `;

                    tbody.appendChild(row);

                    // ⭐ Rebuild course dropdown using curriculum + category
                    const categorySelect = row.children[0].querySelector("select");
                    const courseSelect = row.children[1].querySelector("select");
                    const customInput = row.children[1].querySelector("input");

                    // Trigger category change to repopulate course list
                    onCategoryChange(categorySelect, g.GradeLevel);

                    // Restore saved course selection
                    if (sub.CourseName) {
                        courseSelect.value = sub.CourseName;
                    }

                    // Restore custom course input visibility
                    if (sub.CourseName === "Other") {
                        customInput.classList.remove("hidden");
                        customInput.value = sub.CustomCourseName || sub.Name || "";
                    } else {
                        customInput.classList.add("hidden");
                    }

                });

                updateGPA(g.GradeLevel);
            });
        }


        if (savedTranscript) {
            loadSavedTranscript(savedTranscript);
        }

    </script>



