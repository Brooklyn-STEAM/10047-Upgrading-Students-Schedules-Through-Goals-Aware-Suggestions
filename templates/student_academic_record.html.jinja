        function forceNumeric(input) {
            input.value = input.value.replace(/[^0-9]/g, "");
        }

        function forceDecimal(input) {
            // Remove invalid characters
            input.value = input.value.replace(/[^0-9.]/g, "");

            // Prevent more than one decimal point
            const parts = input.value.split(".");
            if (parts.length > 2) {
                input.value = parts[0] + "." + parts[1];
            }
        }


        function onCurriculumChange(select) {
            selectedCurriculum = select.value || "OTHER";

            // Optional: refresh existing rows' course dropdowns
            document.querySelectorAll("[data-grade-table]").forEach(tbody => {
                const g = tbody.getAttribute("data-grade-table");
                tbody.querySelectorAll("tr").forEach(row => {
                    const categorySelect = row.children[0].querySelector("select");
                    if (!categorySelect) return;
                    onCategoryChange(categorySelect, g, { preserveSelection: true });
                });
            });
        }




        function getCoursesForCategory(category) {
            if (!selectedCurriculum || !courseOptions[selectedCurriculum]) return [];
            if (!courseOptions[selectedCurriculum][category]) return [];

            const block = courseOptions[selectedCurriculum][category];
            const list = block.high_school || [];

            if (!list.includes("Other")) {
                return [...list, "Other"];
            }

            return list;
        }





        function onCategoryChange(select, g, options = {}) {
            const row = select.closest("tr");
            const courseSelect = row.children[1].querySelector("select");
            const customInput = row.children[1].querySelector("input");

            const category = select.value;
            const previousValue = options.preserveSelection ? courseSelect.value : "";

            courseSelect.innerHTML = `<option value="">Select course</option>`;

            // ❗ FIX: category must exist inside the selected curriculum
            if (!category || !courseOptions[selectedCurriculum] || !courseOptions[selectedCurriculum][category]) {
                customInput.classList.add("hidden");
                customInput.value = "";
                return;
            }

            // ❗ FIX: get courses from curriculum → category
            const list = getCoursesForCategory(category);

            list.forEach(c => {
                const opt = document.createElement("option");
                opt.value = c;
                opt.textContent = c;
                courseSelect.appendChild(opt);
            });

            if (options.preserveSelection && previousValue) {
                courseSelect.value = previousValue;
            }

            customInput.classList.add("hidden");
            customInput.value = "";
        }



        function onCourseChange(select, g) {
            const row = select.closest("tr");
            const customInput = row.children[1].querySelector("input");

            if (select.value === "Other") {
                customInput.classList.remove("hidden");
            } else {
                customInput.classList.add("hidden");
                customInput.value = "";
            }
        }

